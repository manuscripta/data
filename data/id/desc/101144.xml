                        <bindingDesc>
                            <binding contemporary="false">
                                <p>Early modern binding. Parchment over cardboard. 5 raised bands and endbands. <locus from="Spine" to="Spine" scheme="other"/>, in ink: <quote>SPECVLVM B. VIRGINIS IACOBI DE VORAGINE</quote>; in ink: <quote>J. de Voragine <supplied reason="illegible">S</supplied>peculum de beata Virgine</quote>; stamped in gold: <quote>A 161</quote>; ink on paper label: <quote>N<hi rend="super">o</hi> 49.</quote>; ink on paper label: <quote>e. 30. 5. 8.</quote>; ink on torn paper label: <quote>156</quote>.</p>
                                <p>
                                    <dimensions type="binding">
                                        <height quantity="300" unit="mm"/>
                                        <width quantity="220" unit="mm"/>
                                        <depth quantity="40" unit="mm"/>
                                    </dimensions>
                                </p>
                            </binding>
                        </bindingDesc>
                    </physDesc>
                    <history>
                        <origin>
                            <p>
                                <origPlace>
                                    <placeName cert="low" ref="https://www.manuscripta.se/place/100104">Germany</placeName>
                                </origPlace>, <origDate notAfter="1500" notBefore="1401">15th century</origDate>. The origin and dating is tentatively based on the watermarks. An addition in German on <locus from="152v" to="152v" scheme="folios"/> (<quote>lach lieb lach</quote>) also indicates Germany.</p>
                        </origin>
                        <provenance>
                            <p>Early provenance unknown. On <locus from="152v" to="152v" scheme="folios"/> there is an addition dated to <date when="1513"/>. Later the manuscript was acquired by <persName ref="https://www.manuscripta.se/person/102544">Paul Petau</persName>, whose son <persName ref="https://www.manuscripta.se/person/102689"> Alexandre Petau </persName>'s signature is found on <locus from="1r" to="1r" scheme="folios"/> (dated to <date when="1649"/>). The manuscript was acquired from Petau by <persName ref="https://www.manuscripta.se/person/100086">Queen Christina</persName> and brought to Sweden. Of the labels on the <locus from="Spine" to="Spine" scheme="other"/>, <quote>49</quote> refers to the catalogue of 1734 (U 125e) where it is listed as <quote>Theol. in fol. no 49</quote>; <quote>e. 30. 5. 8. </quote>refers to Hammarsköld's catalogue from the 19th century (U 133). The signum <quote>156</quote> has not been identified.</p>
                        </provenance>
                    </history>
                    <msPart>
                        <msIdentifier>
                            <idno type="codicologicalUnit">1</idno>
                        </msIdentifier>
                        <msContents>
                            <textLang mainLang="la"/>
                            <msItem>
                                <locus from="1ra" to="145ra" scheme="folios"/>
                                <author>
                                    <persName ref="https://www.manuscripta.se/person/102683"> Jacobus de Voragine </persName>
                                </author>
                                <title type="desc">Sermones de beata Virgine</title>
                                <rubric>Incipit speculum de beata virgine Iacobi de voragine</rubric>
                                <incipit>
                                    <supplied reason="omitted">A</supplied>Bstinecia multipliciter fuit in beatissima maria virgine gloriosa </incipit>
                                <explicit>Illa tamen licet specialiter designatur que materna transfixit uiscera domino in cruce moriente Deo gracias laus deo</explicit>
                                <note> No modern edition of the text exists. It was printed in <ref target="https://mdz-nbn-resolving.de/urn:nbn:de:bvb:12-bsb10165719-2">Paris 1503</ref>.</note>
                            </msItem>
                            <msItem>
                                <locus from="145va" to="147rb" scheme="folios"/>
                                <title type="desc">Sermon on the Trinity</title>
                                <rubric>Sermo de trinitate bonus</rubric>
                                <incipit>Amen amen dico tibi quia quod scimus loquimur (John 3:11) <gap reason="editorial"/> Nos igitur alta sapientibus relinquentes humilia et plana dicamus</incipit>
                                <explicit>Synodus nycena edidit et sanctus Ieronymus ipsum in fine psalmorum decantandum instituit Rogemus et cetera Laus deo</explicit>
                                <note>
                                    <locus from="147v" to="151v" scheme="folios"/>: guidelines, but not text; <locus from="152" to="152" scheme="folios"/>: blank.</note>
                            </msItem>
                        </msContents>
