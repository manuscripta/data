                                <author>
                                    <persName ref="https://www.manuscripta.se/person/100481"> Birgitta Birgersdotter </persName>
                                </author>
                                <title type="uniform">Fragments of the Revelations, Books 1, 2, 4, 5, and 6.</title>
                                <incipit>heliia 3:us mons erat fortitudo sampsonis</incipit>
                                <explicit>cognicionem voluntatis mee quam si mandata non</explicit>
                                <note>This collection consists of ten leaves from the same codex. The leaves belong to the following books of the Revelations:<locus from="1" to="1" scheme="folios"/>: Rev. 1, 51:7-52:12; <locus from="2" to="2" scheme="folios"/>: Rev. 1, 4:9-6:2; <locus from="3" to="3" scheme="folios"/>: Rev. 1, 10:15-10:33; <locus from="4" to="4" scheme="folios"/>: Rev. 2, 6:24-7:28; <locus from="5" to="5" scheme="folios"/>: Rev. 5, 15:44-16:21; <locus from="6" to="6" scheme="folios"/>: Rev. 6, 93:2-97:10; <locus from="7" to="7" scheme="folios"/>: Rev. 6, 12:7-15:17; <locus from="8" to="8" scheme="folios"/>: Rev. 4, 106:2-107:25; <locus from="9" to="9" scheme="folios"/>: Rev. 4, 102:9-106:2; <locus from="10" to="10" scheme="folios"/>: Rev. 6, 16:1-19:27.</note>
                            </msItem>
                        </msContents>
