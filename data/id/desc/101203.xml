                                <locus from="3r" to="14v" scheme="folios"/>
                                <title type="desc">Calendar</title>
                                <note>
                                    <p>
                                        Notable feasts: </p>
                                    <p>
                                        <locus from="3r" to="3r" scheme="folios"/>: St Macarius (15 Jan.); </p>
                                    <p>
                                        <locus from="4r" to="4r" scheme="folios"/>: St Vedast and St Amand (6 Feb.); </p>
                                    <p>
                                        <locus from="5v" to="5v" scheme="folios"/>: St Gertrude (17 Mar.); </p>
                                    <p>
                                        <locus from="6r" to="6r" scheme="folios"/>: St Mary of Egypt (9 Apr.); </p>
                                    <p>
                                        <locus from="9v" to="9v" scheme="folios"/>: St Germanus (31 July); </p>
                                    <p/>
                                    <p/>
                                    <p/>
                                    <p>
                                        <locus from="10v" to="10v" scheme="folios"/>: St Hiero (17 Aug.); </p>
                                    <p>
                                        <locus from="11r" to="11r" scheme="folios"/>: St Philip (13 Sep.); </p>
                                    <p>
                                        <locus from="14r" to="14r" scheme="folios"/>: St Nicasius (14 Dec.). </p>
                                    <p>
                                        <locus from="15r" to="15r" scheme="folios"/>: ruled, but no text. </p>
                                    <p/>
                                </note>
                            </msItem>
                            <msItem>
                                <locus from="15v" to="52v" scheme="folios"/>
                                <title type="desc">Hours of the Virgin</title>
                                <rubric>Incipiunt hore beate marie</rubric>
                                <incipit>DOmine laba mea aperies <gap reason="editorial"/> Inuitatorium Aue maria gracia plena</incipit>
                                <explicit>a presenti liberari tristicia et eterna perfrui leticia Per eundem christum dominum nostrum Amen Benedicamus domino Deo gracias</explicit>
                                <note>
                                    <p>
                                        <locus from="15v" to="15v" scheme="folios"/>: full-page miniature. <locus from="51r" to="51r" scheme="folios"/>: ruled, but no text. <locus from="51v" to="52v" scheme="folios"/>: three full-page miniatures. </p>
                                    <p/>
                                </note>
                            </msItem>
                            <msItem>
                                <locus from="53r" to="62r" scheme="folios"/>
                                <title type="desc">Seven penitential psalms</title>
                                <rubric>Incipunt septem psalmi antiphona</rubric>
                                <incipit>Ne reminiscaris domine Domine ne in furore tuo arguas</incipit>
                                <explicit>neque vindictam sumas de peccatis nostris</explicit>
                            </msItem>
                            <msItem>
                                <locus from="62r" to="66r" scheme="folios"/>
                                <title type="desc">Litany</title>
                                <rubric>Letania</rubric>
                                <incipit>Kyrieleyson Christeleyson</incipit>
                                <explicit>Qui viuis et regnas deus per omnia secula seculorum Amen</explicit>
                            </msItem>
                            <msItem>
                                <locus from="66v" to="79v" scheme="folios"/>
                                <title type="desc">Office for the dead</title>
                                <rubric>hic secuntur vigilie mortuorum </rubric>
                                <incipit>antiphona Placebo DIlexi quoniam exaudiet</incipit>
                                <explicit>Qui viuis et regnas deus Per omnia secula seculorum Amen A porta inferi Erue domine animas eorum Requiescant in pace Amen</explicit>
                                <note>
                                    <locus from="66v" to="66v" scheme="folios"/>: full-page miniature. <locus from="80r" to="81r" scheme="folios"/>: ruled, but no text. </note>
                            </msItem>
                            <msItem>
                                <locus from="81v" to="91r" scheme="folios"/>
                                <title type="desc">Prayers to be read in Jerusalem</title>
                                <rubric>Incipiunt oraciones processionis fratrum minorum et peregrinorum sancte ad singula loca sancta in ecclesia sancti sepulcri et primo in capella beate marie ad columpnam </rubric>
                                <incipit>Antiphona Apprehendit ihesum pilatus ad columpnam</incipit>
                                <explicit>cum sanctis et electis tuis consequantur Qui viuis et regnas deus per omnia secula seculorum Amen</explicit>
                                <note>
                                    <locus from="81v" to="81v" scheme="folios"/>: full-page miniature. For a discussion and transcription of this and the following group of prayers see <bibl>
                                        <title type="short" ref="https://www.manuscripta.se/bibl/107388">Rudy (2000)</title>
                                        <citedRange from="264" to="273" unit="page"/>
                                    </bibl>. </note>
                            </msItem>
                            <msItem>
                                <locus from="91v" to="96r" scheme="folios"/>
                                <title type="desc">Prayers to be read in Betlehem</title>
                                <rubric>Orationes que debent dici in bethleem faciendo processionem et primo in altari ubi stella disparuit trium magorum </rubric>
                                <incipit>Stella quam uiderant magi in oriente</incipit>
                                <explicit>Domine ihesu christe qui ut legem impleres et veram carnem <gap reason="editorial"/> Qui viuis et regnas deus Per omnia secula seculorum Amen </explicit>
                                <note>
                                    <locus from="91v" to="91v" scheme="folios"/>: full-page miniature. <locus from="96v" to="97v" scheme="folios"/>: ruled, but no text. </note>
                            </msItem>
                            <msItem>
                                <locus from="98r" to="102r" scheme="folios"/>
                                <title type="desc">Hours of the Holy Cross</title>
                                <rubric>Incipiunt hore sancte crucis</rubric>
                                <incipit>DOmine labia mea aperies <gap reason="editorial"/> PAtris sapiencia veritas diuina</incipit>
                                <explicit>Sit labori consonans consors sim corone Amen Benedicamus domino Deo gracias</explicit>
                                <note>
                                    <locus from="98r" to="98v" scheme="folios"/>: two full-page miniatures. </note>
                            </msItem>
                            <msItem>
                                <locus from="102v" to="107r" scheme="folios"/>
                                <title type="desc">Hours of the Holy Spirit</title>
                                <rubric>Incipiunt hore sancto spiritu</rubric>
                                <incipit>DOmine labia mea aperies <gap reason="editorial"/> NObis sancti spiritus gracia sit data</incipit>
                                <explicit>Vt uiuamus iugiter celi regione Amen Benedicamus domino Deo gracias</explicit>
                                <note>
                                    <locus from="102v" to="102v" scheme="folios"/>: full-page miniature. <locus from="107v" to="111v" scheme="folios"/>: ruled, but no text. </note>
                            </msItem>
