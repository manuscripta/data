                                <incipit>UNIuersum tempus presentis uite in quaturorum distinguitur</incipit>
                                <explicit defective="unknown">representat ecclesia ab octaua pentecosten usque <add place="margin">ad</add> aduentum domini</explicit>
                                <finalRubric>Explicit prologus super librum de legendis sanctorum in quaturom capitula distinctum </finalRubric>
                            </msItem>
                            <msItem>
                                <locus from="1rb" to="2va" scheme="folios"/>
                                <title type="desc">Table of contents</title>
                                <note>Chapter 110 omitted in the list but found in the text, chapter 114 (<quote>De sancto Tyburtho</quote>) is not found in the text.</note>
                            </msItem>
                            <msItem>
                                <locus from="2va" to="277ra" scheme="folios"/>
