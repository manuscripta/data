                                </author>
                                <title type="desc">Legenda Aurea</title>
                                <rubric>Incipit de aduentu domini</rubric>
                                <incipit>Aduentus domini per quatuorum septimanas agitur </incipit>
                                <explicit defective="unknown">Quod ipse nobis prestare dignetur qui uiuit et regnat deus per omnia secula seculorum Amen</explicit>
                                <finalRubric>Explicit legenda sanctorum</finalRubric>
                                <note>
                                    <p> Under the final rubric a piece (possibly containing a colophon) has been cut out.</p>
                                    <p>
                                        <locus from="277v" to="277v" scheme="folios"/>: blank.</p>
                                </note>
                                <bibl>
