                        <additions>
                            <p>
                                <locus from="LCI" to="LCI" scheme="other"/>
                                <note>Top of page, in black ink by a modern hand: <quote>Inköpt till Kongl. Bibliotheket på Heberles auktion i Cölln 5 April 1853. No 3603 Pris 2 Thaler 28 gr.</quote>, <quote>Pris</quote> (repeated); bottom left corner: National Library book label with current signum. There is also text visible on the other side of the pastedown, this text is not legible.</note>
                            </p>
                            <p>
                                <locus from="RCI" to="RCI" scheme="other"/>
                                <note>Centre page, in red crayon: <quote>270<unclear quantity="1" unit="chars"/>
                                    </quote>; left margin, in pencil: <quote>wl?</quote>.</note>
                            </p>
                        </additions>
                        <bindingDesc>
                            <binding contemporary="unknown">
                                <p>Medieval binding. Parchment over cardboard. 5 double raised bands. <locus from="Spine" to="Spine" scheme="other"/>, in brown ink: <quote>Sermones fratris Chunradi de Saxonia de Sanctis</quote>; stamped in gold: <quote>A 204</quote>.<locus from="LCO" to="LCO" scheme="other"/>, traces of writing in brown ink. <locus from="1" to="1" scheme="folios"/> and <locus from="140" to="140" scheme="folios"/>: fragments from late Carolingian theological manuscript with notation.</p>
                                <p>
                                    <dimensions type="binding">
                                        <height quantity="175" unit="mm"/>
                                        <width quantity="135" unit="mm"/>
                                        <depth quantity="30" unit="mm"/>
                                    </dimensions>
                                </p>
                                <condition>
                                    <locus from="Spine" to="Spine" scheme="other"/> cracked. The parchment on the covers are of a later date.</condition>
                            </binding>
                        </bindingDesc>
