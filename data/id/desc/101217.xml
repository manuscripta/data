                        <msContents>
                            <textLang mainLang="la"/>
                            <msItem>
                                <locus from="1ra" to="109va" scheme="folios"/>
                                <author>
                                    <persName ref="https://www.manuscripta.se/person/102697"> Henricus de Frimaria </persName>
                                </author>
                                <title type="desc">Commentary on Peter Lombard's Four Books of Sentences</title>
                                <rubric>Queritur circa principium quarti libri </rubric>
                                <incipit>Circa principium 4<hi rend="super">i</hi> sententiarum queritur vtrum tota theologia traxerit suam totam scienciam a deo Et videtur quod non</incipit>
                                <explicit>tam non posset et bono animo primam/itaque penitenciam seu penam explere etiam non precaret </explicit>
                                <note>After the main text on <locus from="109va" to="110ra" scheme="folios"/> follows a list of topics or chapters by different hand. <locus from="110v" to="110v" scheme="folios"/>: blank.</note>
                                <colophon>
                                    <locus from="109va" to="109va" scheme="folios"/>Et sic est finis illius 4<hi rend="super">i</hi> sentenciarum Anno domini 1406 in die marci ewangeliste hora quasi vndecima ante meridiem pro quo cunctorum gubernator ihesus christus marie filius super omnia in secula seculorum sit benedictus </colophon>
                            </msItem>
                            <msItem>
                                <locus from="111ra" to="166vb" scheme="folios"/>
                                <title type="desc">Theological treatise regarding the sacraments</title>
                                <incipit>Divino adiutorio aliqua de sacramentis dubia circa tractatum gydonis movebo </incipit>
                                <explicit>pro quo christus ihesus noster rex regum sit benedictus in secula seculorum amen et cetera </explicit>
                            </msItem>
                        </msContents>
