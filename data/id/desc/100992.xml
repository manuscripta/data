                                <locus from="1r" to="239v" scheme="folios"/>
                                <author>
                                    <persName ref="https://www.manuscripta.se/person/102663"> Irenaeus </persName>
                                </author>
                                <title type="desc">Against Heresies</title>
                                <msItem>
                                    <locus from="1r" to="64v" scheme="folios"/>
                                    <title type="desc">Book 1</title>
                                    <rubric>Hirenei episcopi lugdunensis contra omnes hereticos libri numero quinque</rubric>
                                    <incipit>
                                        <supplied reason="omitted">Q</supplied>UATENUS UERITATEM REFUTANTES QUIDAM </incipit>
                                    <explicit>sed et vulnerantes vndique bestiam</explicit>
                                    <finalRubric>Explicit liber Hyrenei primus </finalRubric>
                                </msItem>
                                <msItem>
                                    <locus from="64v" to="118r" scheme="folios"/>
                                    <title type="desc">Book 2</title>
                                    <rubric>Incpit secundus Hec insunt in secundo libro redargutionis et euersionis falso cognomenta agnitionis </rubric>
                                    <incipit>OStensio quod neque extra pleroma sit </incipit>
                                    <explicit>in medio omnibus amantibus verutatem </explicit>
                                    <finalRubric>Explicit liber <del>s</del> secundus <del>incipi</del>
                                    </finalRubric>
                                </msItem>
                                <msItem>
                                    <locus from="118r" to="165r" scheme="folios"/>
                                    <title type="desc">Book 3</title>
                                    <rubric>Incipit lib<del>e</del>ri tercii<del>us</del> tabula</rubric>
                                    <incipit>a quibus et quodadmodum ewangelium acceperit ecclesia</incipit>
                                    <explicit>qui et solus est deus et pater domini nostri ihesu christi amen</explicit>
                                    <finalRubric>Explicit liber tercius</finalRubric>
                                </msItem>
                                <msItem>
                                    <locus from="165r" to="210v" scheme="folios"/>
                                    <title type="desc">Book 4</title>
                                    <rubric>Incipit liber quartus Et primo ipsius tabula</rubric>
                                    <incipit>ostensio quoniam dominus unum deum solum </incipit>
                                    <explicit>in quinque exercentes libris </explicit>
                                    <finalRubric>Explicit liber Hyrenei quartus </finalRubric>
                                </msItem>
                                <msItem>
                                    <locus from="210v" to="239v" scheme="folios"/>
                                    <title type="desc">Book 5</title>
                                    <rubric>Incipit quintus </rubric>
                                    <incipit>TRaductis dilectissime omnibus hereticis </incipit>
                                    <explicit>fiet secundum ymaginem et similitudinem dei amen</explicit>
                                    <finalRubric>Expliciunt libri beati hyrinei martiris numero quinque </finalRubric>
                                    <note>
                                        <locus from="240" to="242" scheme="folios"/>: guidelines, but no text.</note>
                                </msItem>
                                <note>Quires 4 and 5 have been placed in the wrong order. The text on <locus from="48v" to="48v" scheme="folios"/> is continued on <locus from="63r" to="63r" scheme="folios"/> and <locus from="49r" to="62v" scheme="folios"/> should follow after <locus from="78v" to="78v" scheme="folios"/>.</note>
                                <bibl>
                                    <title type="short" ref="https://www.manuscripta.se/bibl/107400">Harvey (1857)</title>
                                </bibl>
                            </msItem>
