                            <msItem>
                                <locus from="2r" to="11v" scheme="folios"/>
                                <textLang mainLang="la"/>
                                <title type="desc">Alphabetical index </title>
                                <rubric xml:lang="la">Legem statuit ei in via quam elegit Elegimus namque non tamen latam viam mandatorum dei ymmo artam semitam consiliorum que ergo nobis statuta est in legem seruandam ad salutem Hec via et semita electa continentur in regula sancti saluatoris, et Augustini, addicionibus prioris, declaracionibus doctorum, libro vsuum, et actis capituli hec omnia in tabula</rubric>
                                <incipit>ABbatissa eligatur et sit caput et domina omnium</incipit>
                                <explicit defective="false">Christus ihesus est dator regule sancte huius ordinisque fundator 1 b c Ipse enim est principium et finis alpha et o deus et homo ipsi honor et gloria in seculis</explicit>
                                <note>The index refers to the contemporary foliation and paragraphs in the manuscript.</note>
                            </msItem>
                            <msItem>
                                <locus from="12r" to="24v" scheme="folios"/>
                                <textLang mainLang="la"/>
                                <title type="desc">Regula Salvatoris (The Birgittine Rule, the first-person version)</title>
                                <rubric>Regula sancti saluatoris in prima persona. Narratur hic modus qualiter domina Birgitta habebat reuelaciones diuinas (...) Capitulum 1 prologi</rubric>
                                <incipit>In dominio Regis noruegie qui est ad septentrionem omnium regium</incipit>
                                <explicit defective="false">…ego autem perficiam dum mihi placuerit</explicit>
                                <finalRubric>Explicit regula saluatoris. Amen</finalRubric>
                                <bibl>
                                    <title type="short" ref="https://www.manuscripta.se/bibl/107122">Eklund (1975)</title>
                                    <citedRange from="100" to="139" unit="page"/>
                                </bibl>
                            </msItem>
                            <msItem>
                                <locus from="25r" to="28v" scheme="folios"/>
                                <author>
                                    <persName ref="https://www.manuscripta.se/person/102515">Augustine of Hippo</persName>
                                </author>
                                <title type="desc">The Rule of St Augustine</title>
                                <rubric>Regula sancti Augustini episcopi</rubric>
                                <incipit>ANte omnia fratres karissimi diligatur deus deinde proximus</incipit>
                                <explicit defective="false">vt ei debitum dimittatur et in temptacionem ne inducatur Amen</explicit>
                                <bibl>
                                    <title type="short" ref="https://www.manuscripta.se/bibl/107123">Verheijen (1967)</title>
                                    <citedRange from="417" to="437" unit="page"/>
                                </bibl>
                            </msItem>
                            <msItem>
                                <locus from="28v" to="39v" scheme="folios"/>
                                <title type="desc">Additions to the rule</title>
                                <rubric>Incipiunt addiciones domini prioris petri ad regulam saluatoris Et primo de gradibus seu signis vere dilectionis. Capitulum primum</rubric>
                                <incipit>HWmilitas vera est timere deum omni hora non amare propriam voluntatem</incipit>
                                <explicit defective="false">Sorores sepeliantur in ambitibus et in ecclesia infra crates Et similiter fratres. Amen</explicit>
                                <bibl>
                                    <title type="short" ref="https://www.manuscripta.se/bibl/107129">Nyberg (1972–1974)</title>
                                    <citedRange from="42" to="106" unit="page"/>
                                </bibl>
                            </msItem>
                            <msItem>
                                <locus from="39v" to="42r" scheme="folios"/>
                                <title type="desc">Excerpts from St Birgitta, Revelationes extravagantes 10; 22-23; 13-15; 21; 20; 33</title>
                                <rubric>Sequntur reuelaciones pertinentes ad statuta Et primo de organis non habendis</rubric>
                                <incipit>Christus loquitur filii israel quia carnales erant multa</incipit>
                                <explicit defective="false">et confessori in spiritualibus. Amen.</explicit>
                                <bibl>
                                    <title type="short" ref="https://www.manuscripta.se/bibl/107126">Hollman (1956)</title>
                                    <citedRange from="123" to="123" unit="page"/>
                                    <citedRange from="125" to="127" unit="page"/>
                                    <citedRange from="131" to="133" unit="page"/>
                                    <citedRange from="147" to="148" unit="page"/>
                                </bibl>
                            </msItem>
                            <msItem>
                                <locus from="42r" to="42v" scheme="folios"/>
                                <title type="desc">Rules for deacons and subdeacons in the Birgittine Order</title>
                                <rubric>Dyaconus et subdyaconus sic ministrabunt induti ad missas</rubric>
                                <incipit>Dyaconi ministrabunt vicissim ad altaria secundum ordinem suum</incipit>
                                <explicit defective="unknown">Item dyaconus thurificabit omnem inhabitacionem fratrum in vigilia natiuitatis christi et vigilia epyphanie domini finitis vesperis</explicit>
                                <note>
                                    <locus from="43r" to="43r" scheme="folios"/> Blank page.</note>
                            </msItem>
                            <msItem>
                                <locus from="43v" to="59v" scheme="folios"/>
                                <title type="desc">The Vadstena Constitutions (Constitutio Vadstenensis)</title>
                                <rubric>Hec est constitucio Watzstenensis qualiter diuinum officium et festa seu solemnitates debent obseruari in monasterio </rubric>
                                <incipit>SIcut regula sancti saluatoris precipit fratres clerici</incipit>
                                <explicit defective="false">vt in illo legat vel studeat sub horis vel in missa. Amen.</explicit>
                            </msItem>
                            <msItem>
                                <locus from="59v" to="62v" scheme="folios"/>
                                <title type="desc">Declaraciones dominorum</title>
                                <rubric>Declaraciones dominorum de nuceria cardinalis Vrbeuetani alfonsi et aliorum vt infra patet. de roma misse</rubric>
                                <incipit>HIc continentur declaraciones dubiorum missorum de monasterio sancte Marie in Vastzenom</incipit>
                                <explicit defective="false">Videtur quod cum consilio sui proprii confessoris ipse enim diligencius examinauerat consciencias earum Amen</explicit>
                                <finalRubric>Expliciunt declaraciones dominorum prius positorum super regulam sancti saluatoris</finalRubric>
                            </msItem>
                            <msItem>
                                <locus from="63r" to="82r" scheme="folios"/>
                                <title type="uniform">The Customary of the Vadstena Brothers (Liber usuum)</title>
                                <rubric xml:lang="la">Ihesu christi nomine inuocato humiliter et deuote Incipit prologus in librum vsuum fratrum monasterii sancte marie virginis et birgitte in Vatzstenom</rubric>
                                <incipit>QVoniam exemplo primitiue ecclesie congregacionisque fidelium</incipit>
                                <explicit defective="false" xml:lang="la">vt notatur super verbo nigrorum supra et secundum Iohannem andree</explicit>
                                <note>Scribal corrections in the margin <locus from="64r" to="77r" scheme="folios"/>. <locus from="82v" to="82v" scheme="folios"/>: blank.</note>
                                <bibl>
                                    <title type="short" ref="https://www.manuscripta.se/bibl/107107">Risberg (2003)</title>
                                    <citedRange from="77" to="198" unit="page"/>
                                </bibl>
                            </msItem>
                            <msItem>
                                <locus from="83r" to="88v" scheme="folios"/>
                                <title type="desc">Confirmation of the decisions made at the Birgittine general chapter in Gnadenberg 1487</title>
                                <incipit xml:lang="la">Vilhelmus dei gracia Eystetensis alias Aureatensis ecclesie Episcopus Sacrosancte Maguntinensis Sedis Cancellarius</incipit>
                                <explicit xml:lang="la">presentibus ibidem venerabili et religiosis deuotis nobis in christo dilectis fratribus Iohanne priore monasterii sancti Iohannis Baptiste in Rebdorff dicte nostre diocesis ordinis sancti Augustini canonicorum regularum et Wolfgango Zannazeller accolito dicte Augustinensis dyocesis testibus ad premissa vocatis specialiter et rogatis</explicit>
                                <colophon xml:lang="la">
                                    <locus from="88v" to="88v" scheme="folios"/>Et ego Iohannes Vogt Clericus Eystetensis dyocesis publicus apostolica et imperiali auctoritatibus notarius dictique reuerendissimi in christo patris domini Vilhelmi Episcopi Eystetensis Executoris et Commissarii Scriba Iuratus Quia ... signavi rogatus et requisitus in fidem et testimonium omnium et singulorum premissorum</colophon>
                                <filiation>
                                    <idno type="msRef"/>
                                </filiation>
                            </msItem>
