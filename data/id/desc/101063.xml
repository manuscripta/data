                                        <depth quantity="45" unit="mm"/>
                                    </dimensions>
                                </p>
                                <condition>Leather heavily worn. <locus from="LCO" to="LCO" scheme="other"/> loose, <locus from="Spine" to="Spine" scheme="other"/> visible.</condition>
                            </binding>
                        </bindingDesc>
