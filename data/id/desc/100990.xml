                    <history>
                        <origin>
                            <p>
                                <origPlace>
                                    <placeName ref="https://www.manuscripta.se/place/100211">Bohemia</placeName>
                                </origPlace>, <origDate when="1398">1398</origDate>. The colophon on <locus from="135r" to="135r" scheme="folios"/> gives the date and states that the text was written by <persName ref="https://www.manuscripta.se/person/102763">Jan Hus</persName> himself.</p>
                        </origin>
                        <provenance>
                            <p>The signum <quote>N<hi rend="super">o</hi> 9.</quote> on <locus from="LCO" to="LCO" scheme="other"/> refers to the catalogue of 1734 (U 125e). The signum <quote>XIII</quote> on the <locus from="Spine" to="Spine" scheme="other"/> refers to <bibl>
                                    <title type="short" ref="https://www.manuscripta.se/bibl/107330">Stephens (1847)</title>
                                    <citedRange from="35" to="39" unit="page">page 35–39.</citedRange>
                                </bibl>
                            </p>
                        </provenance>
                        <acquisition>
                            <p>Taken from <placeName ref="https://www.manuscripta.se/place/100067">Prague</placeName> in <date when="1649"/> as spoils of war.</p>
                        </acquisition>
                    </history>
