                    <history>
                        <origin>
                            <p>
                                <origPlace>
                                    <placeName ref="https://www.manuscripta.se/place/100081">Sweden</placeName>
                                </origPlace>, <origDate notAfter="1400" notBefore="1301">14th century</origDate>
                            </p>
                        </origin>
                        <provenance>
                            <p>According to <bibl>
                                    <title ref="https://www.manuscripta.se/bibl/107431">Paulsson</title>
                                    <citedRange from="26" to="26" unit="page"/>
                                </bibl>, the volume was first used at <orgName ref="https://www.manuscripta.se/org/100009">Strängnäs cathedral</orgName> ca <date when="1350"/>. It was still in use there in <date when="1541"/>, as shown by an annotation on <locus from="3v" to="3v" scheme="folios"/>.</p>
                        </provenance>
                        <provenance>
                            <p>The <orgName ref="https://www.manuscripta.se/org/100059">Antiquities Archive</orgName>. The current signum, <quote>A 28</quote>, was first established in Helin’s catalogue from the 1720s (U 91:2:2).</p>
                        </provenance>
                        <acquisition>
                            <p>From the <orgName>Antiquities Archive</orgName> to the <orgName ref="https://www.manuscripta.se/org/100151">Royal Library</orgName> in <date when="1780"/>.</p>
                        </acquisition>
                    </history>
