                    <history>
                        <origin>
                            <p>
                                <origPlace>
                                    <placeName cert="low" ref="https://www.manuscripta.se/place/100036">Italy</placeName>
                                </origPlace>
                                <origDate notAfter="1450" notBefore="1401"> 15th century, first half.</origDate> Place and date of origin tentatively based on style of script and decoration as well as the coat of arms on <locus from="3r" to="3r" scheme="folios"/>.</p>
                        </origin>
                        <provenance>
                            <p>Early provenance unknown. The manuscript was acquired by <persName ref="https://www.manuscripta.se/person/101061">Sparfwenfeldt</persName> and belonged to his private library. The signum <quote>1 4:o</quote> on the <locus from="Spine" to="Spine" scheme="other"/> refers to the catalogue of 1734 (U125e) and is also mentioned in connection with Sparfwenfeldt's library, see <bibl>
                                    <title type="short" ref="https://www.manuscripta.se/bibl/107280">Lillieblad (1706)</title>
                                    <citedRange from="13" to="13" unit="page"/>
                                </bibl>. The top signum on the <locus from="Spine" to="Spine" scheme="other"/> and the signa on <locus from="1r" to="1r" scheme="folios"/> are unidentified.</p>
                        </provenance>
                        <acquisition>
                            <p>Donated by <persName ref="https://www.manuscripta.se/person/100269">Sparfwenfeldt</persName> to the <orgName ref="https://www.manuscripta.se/org/100004">Royal Library</orgName> in <date when="1702"/>.</p>
                        </acquisition>
