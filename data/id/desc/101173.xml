                        <msContents>
                            <textLang mainLang="la"/>
                            <msItem>
                                <locus from="207ra" to="215vb" scheme="folios"/>
                                <title type="desc">De cura prelatorum </title>
                                <rubric>De cura prelatorum et regimine et cetera</rubric>
                                <incipit>QVasi stella matutina in medio nebule (Eccl. 50:6) id est peccatorum proprietates stelle huius possunt referri ad quemlibet doctorem fidei</incipit>
                                <explicit>sed tamen permittit eum nobis mala swadere In nostro autem arbitrio et velimus ei consentire ?ich?</explicit>
                            </msItem>
                            <msItem>
                                <locus from="215vb" to="223vb" scheme="folios"/>
                                <title type="desc">Excerpta de regimine principium</title>
                                <rubric>Excerpta de Regimine principum et vocatur libellus Fauum mellis</rubric>
                                <incipit>
                                    <sic>Ox</sic> regia ac sanctissima prosapia oriundo suo domino spirituali domino philippo</incipit>
                                <explicit>quo apparent in eius medio nec putrescunt quia non potest intrare calidum Alienum</explicit>
                                <finalRubric>item Ego dubio (dubito?) de fine huius Amen In die marie magdalene</finalRubric>
                            </msItem>
                            <msItem>
                                <locus from="224ra" to="233vb" scheme="folios"/>
                                <title type="desc">Ars moriendi</title>
                                <incipit>Cvm de presentis exilii miseria mortis transitus </incipit>
                                <explicit defective="true">se timet meruisse amorem ut vniatur tibi amore</explicit>
                            </msItem>
                            <msItem>
                                <locus from="234ra" to="238rb" scheme="folios"/>
                                <title type="desc">Disputatio corporis et anime</title>
                                <rubric>disputacio corporis et anime scripta per Gilbertum episcopum Linconiensem</rubric>
                                <incipit>hie vor in ein wind zeit peschach ein jämerlich streit</incipit>
                                <explicit>das wir frölich pey ym pesten vnd sprechen mit</explicit>
                                <finalRubric>Andacht Amen das gesech</finalRubric>
                            </msItem>
                            <msItem>
                                <locus from="238rb" to="242ra" scheme="folios"/>
                                <title type="desc">Dialogue between a lamenting man and reason</title>
                                <rubric>Ad honorem <sic>deus</sic> ac sanctorum apostolorum petri et pauli hanc exhortacionem scripsi </rubric>
                                <incipit>hic introducuntur persone duorum videlicet deflentis hominis </incipit>
                                <explicit>vide ne deinceps condempnas viuendo quod audis et? multis modis mouendo fiat fiat Amen</explicit>
                                <note>
                                    <locus from="242v" to="242v" scheme="folios"/>: blank.</note>
                            </msItem>
                            <msItem>
                                <locus from="242bisr" to="243rb" scheme="folios"/>
                                <title type="desc">Theological text (fragmented)</title>
                                <incipit defective="true">improperando simplicibus fidelibus et dicendo Ecce quomodo viuunt qui meliores merit vos</incipit>
                                <explicit>quia tunc cum magna suscipiet me Quod ipse <sic>prare</sic> (i.e. prestare) dignetur qui viuit et cetera </explicit>
                            </msItem>
                            <msItem>
                                <locus from="243rb" to="253vb" scheme="folios"/>
                                <title type="desc">Expositio canonis</title>
                                <rubric>Exposicio canonis Breuis et vtilis sub bono Stilo <lb/> Exposicio Canonis Breuis et vtilis sub bono stilo iam sequitur</rubric>
                                <incipit>DIcit apostolus Ephesiis vi Induite vos armaturam dei (Eph. 6:11) <gap reason="editorial"/> Hec armatura est vestis sacerdotalis</incipit>
                                <explicit>et subsequitur hominem in bonis operibus et cetera</explicit>
                                <finalRubric>Et sic finis</finalRubric>
                            </msItem>
                            <msItem>
                                <locus from="254ra" to="259va" scheme="folios"/>
                                <title type="desc">Sermon</title>
                                <incipit>BErnhardus o homo quam fructum expectam in hoc seculo huius fructus ruina huius finis mors est</incipit>
                                <explicit>Sanguinis in corpore anima in sangwine Spiritus in anima mens in spiritu et fides in corde christianus in fide hec ille item Amen</explicit>
                            </msItem>
                            <msItem>
                                <locus from="259vb" to="267rb" scheme="folios"/>
                                <title type="desc">Casus in missa </title>
                                <incipit>Qvia sunt casus aliqui qui occurunt in missa sacerdotibus in missa ideo ut de hiis videatur </incipit>
                                <explicit>qui singulis subvenit necessitatibus sit benedictus in secula seculorum Amen </explicit>
                            </msItem>
                            <msItem>
                                <locus from="267rb" to="269va" scheme="folios"/>
                                <title type="desc">Nota de baptisma</title>
                                <rubric>Nota de baptisma</rubric>
                                <incipit>Consequentur dicenda sunt aliquam de baptismo que faciunt de baptismante </incipit>
                                <explicit>que in illis seruanda est de quibus est que ponitur extra de baptismo et eius effectu item hec scripta per magistrum de dinchlspühel</explicit>
                            </msItem>
                            <msItem>
                                <locus from="269vb" to="271va" scheme="folios"/>
                                <title type="desc">Treatise on mass</title>
                                <incipit>Nota auctoritates misse et lege hanc tabulam et invenies qualiter missa precellit et est dignior ceteris oracionibus de audicione</incipit>
                                <explicit>tunc est dare orandum quot annis receperunt vsuram tot annos xv pater noster</explicit>
                            </msItem>
                            <msItem>
                                <locus from="271vb" to="275ra" scheme="folios"/>
                                <title type="desc">Excerpts from various papal bulls</title>
                                <incipit>Pro declaracione Bulle Nycolai quinti de sacro Iubileo Anno domini 1450 proxime futuro sunt notanda </incipit>
                                <explicit>et ad hanc indulgenciam consequendam et? que patet diligenti et cetera</explicit>
                            </msItem>
                            <msItem>
                                <locus from="275ra" to="276vb" scheme="folios"/>
                                <title type="desc">Notes from the Synod of Salzburg 1451</title>
                                <incipit>
                                    <supplied reason="omitted">S</supplied>Acra synodus que convenit in salzpurga Anno domini 1451 die tercia februarii </incipit>
                                <explicit>quo eis <del>nl</del> nichil horribilius accidere poterit<del>t</del> et cetera</explicit>
                            </msItem>
