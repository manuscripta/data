                        <msContents>
                            <textLang mainLang="la"/>
                            <msItem>
                                <locus from="Br" to="Cr" scheme="folios"/>
                                <title type="desc">Blessing of Salt and Water</title>
                                <rubric>Sequitur Exorcismus Salis et aque dominicis diebus</rubric>
                                <incipit>Deus in adiutorium meum intende (Ps. 69:2)</incipit>
                                <explicit>hic et in eterna secula seculorum Amen</explicit>
                            </msItem>
                            <msItem>
                                <locus from="Cr" to="Cv" scheme="folios"/>
                                <title type="desc">Blessing of Wine</title>
                                <rubric>Benediccio vini amoris ewangelium</rubric>
                                <incipit>In principio erat (John 1:1)</incipit>
                                <explicit>ut magnitudinem tuam intelligant Per dominum Deinde Aspergatur et Thurificetur </explicit>
                            </msItem>
                            <msItem>
                                <locus from="Dr" to="Jv" scheme="folios"/>
                                <title type="desc">Calendar</title>
                                <note>
                                    <p> Notable feasts:</p>
                                    <p>
                                        <locus from="Dr" to="Dr" scheme="folios"/>: St Erhard (8 Jan.);</p>
                                    <p/>
                                    <p>
                                        <locus from="Er" to="Er" scheme="folios"/>: translation of St Cunigunde (3 Mar.);</p>
                                    <p/>
                                    <p> St Rupert (27 Mar.);</p>
                                    <p>
                                        <locus from="Fr" to="Fr" scheme="folios"/>: St Florian (4 May);</p>
                                    <p/>
                                    <p>
                                        <locus from="Gr" to="Gr" scheme="folios"/>: St Willibald (7 July);</p>
                                    <p/>
                                    <p> St Kilian (8 July);</p>
                                    <p> St Henry (13 July);</p>
                                    <p>
                                        <locus from="Ir" to="Ir" scheme="folios"/>: translation of St Rupert (24 Sep.);</p>
                                    <p/>
                                    <p> translation of St Virgilius (26 Sep.);</p>
                                    <p> St Wenceslaus (28 Sep.);</p>
                                    <p>
                                        <locus from="Iv" to="Iv" scheme="folios"/>: St Coloman (13 Oct.);</p>
                                    <p> St Wolfgang (31 Oct.);</p>
                                    <p/>
                                    <p>
                                        <locus from="Jr" to="Jr" scheme="folios"/>: St Virgilius (27 Nov.).</p>
                                    <p/>
                                    <p>
                                        <locus from="K" to="K" scheme="folios"/>: blank.</p>
                                </note>
                            </msItem>
                            <msItem>
                                <locus from="1r" to="128r" scheme="folios"/>
                                <title type="desc">Proper of time</title>
                                <incipit>AD te leuaui animam meam deus meus (Ps. 24:1)</incipit>
                                <explicit>et sanguinis tui temporalis precepcio prefigurat Per</explicit>
                                <note>The Proper of time begins with the First Sunday of Advent and the first part ends with Corpus Christi. The Proper of time is continued after the Ordo and Canon missae.</note>
                            </msItem>
                            <msItem>
                                <locus from="128r" to="129v" scheme="folios"/>
                                <title type="desc">Dedication of the church</title>
                                <rubric>In dedicacione ecclesie </rubric>
                                <incipit>Terribilis est locus </incipit>
                                <explicit>tuis omnibus letemur per</explicit>
                            </msItem>
                            <msItem>
                                <locus from="129r" to="130v" scheme="folios"/>
                                <title type="desc">Dedication of an altar</title>
                                <rubric>In dedicacione altaris</rubric>
                                <incipit>Dicit dominus sermones meos quos dedi</incipit>
                                <explicit>auxilii tui munus ostende Per</explicit>
                            </msItem>
                            <msItem>
                                <locus from="130v" to="148v" scheme="folios"/>
                                <title type="desc">Ordo and Canon missae</title>
                                <incipit>Gloria in excelsis</incipit>
                                <explicit>et abii et lauii et vidi et credidi</explicit>
                                <note>
                                    <p>
                                        <locus from="137r" to="137r" scheme="folios"/>: Canon. The leaf that most likely contained the Canon image has been cut out.</p>
                                    <p>
                                        <locus from="137r" to="148v" scheme="folios"/>: the section that starts with the Canon and continues until the end of the Ordo and Canon missae has a different layout compared to the rest of the manuscript.</p>
                                    <p/>
                                </note>
                            </msItem>
                            <msItem>
                                <locus from="149r" to="175v" scheme="folios"/>
                                <title type="desc">Proper of time (continued)</title>
                                <rubric>Dominica prima post octauam pasche</rubric>
                                <incipit>MIsericordia domini plena est</incipit>
                                <explicit>quod sumpsimus meditacione curetur Per</explicit>
                                <note>The second part of the Proper of time appears to regress, beginning with the First Sunday after the octave of Easter, while the first part ended with Corpus Christi. It ends with the Twenty-fifth Sunday after the octave of Pentecost.</note>
                            </msItem>
                            <msItem>
                                <locus from="175v" to="273r" scheme="folios"/>
                                <title type="desc">Proper of saints</title>
                                <rubric>Incipit liber de sanctis In vigilia sancti Andree</rubric>
                                <incipit>Dominus secus mare galilee (Matt. 4:16)</incipit>
                                <explicit>eterna similiter capiamus nutrimenta Per</explicit>
                                <note>
                                    <p> The Proper of saints begins with the vigil for Saint Andrew (29 November) and ends with Saint Catherine (25 November) and an office for the evangelists.</p>
                                    <p>
                                        <locus from="186r" to="186r" scheme="folios"/>: St Erhard;</p>
                                    <p/>
                                    <p>
                                        <locus from="198v" to="198v" scheme="folios"/>: St Cunigunde;</p>
                                    <p/>
                                    <p>
                                        <locus from="201r" to="201r" scheme="folios"/>: St Rupert;</p>
                                    <p/>
                                    <p>
                                        <locus from="208r" to="208r" scheme="folios"/>: St Florian;</p>
                                    <p/>
                                    <p>
                                        <locus from="227v" to="227v" scheme="folios"/>: St Kilian;</p>
                                    <p/>
                                    <p>
                                        <locus from="230r" to="230r" scheme="folios"/>: St Henry;</p>
                                    <p/>
                                    <p>
                                        <locus from="249r" to="249r" scheme="folios"/>: St Hedwig;</p>
                                    <p/>
                                    <p>
                                        <locus from="253v" to="253v" scheme="folios"/>: St Cunigunde;</p>
                                    <p/>
                                    <p>
                                        <locus from="257v" to="257v" scheme="folios"/>: St Rupert, St Wenceslaus;</p>
                                    <p/>
                                    <p>
                                        <locus from="261r" to="261r" scheme="folios"/>: St Coloman;</p>
                                    <p/>
                                    <p>
                                        <locus from="264v" to="264v" scheme="folios"/>: St Wolfgang.</p>
                                    <p/>
                                    <p>
                                        <locus from="273v" to="273v" scheme="folios"/>: ruled, but no text.</p>
                                </note>
                            </msItem>
                            <msItem>
                                <locus from="274r" to="301v" scheme="folios"/>
                                <title type="desc">Common of saints</title>
                                <incipit>Ego autem sicut oliua (Ps. 51:10)</incipit>
                                <explicit>exoramus ut percepti tui sacramenti nos virtute defendas Per</explicit>
                                <finalRubric>Explicit commune sanctorum </finalRubric>
                                <note>
                                    <p>
                                        <locus from="274r" to="274r" scheme="folios"/>: common of apostles;</p>
                                    <p>
                                        <locus from="279r" to="279r" scheme="folios"/>: common of one martyr;</p>
                                    <p/>
                                    <p>
                                        <locus from="283r" to="283r" scheme="folios"/>: common of many martyrs;</p>
                                    <p>
                                        <locus from="290r" to="290r" scheme="folios"/>: common of one confessor and bishop;</p>
                                    <p/>
                                    <p>
                                        <locus from="290v" to="290v" scheme="folios"/>: common of many confessors;</p>
                                    <p/>
                                    <p>
                                        <locus from="294r" to="294r" scheme="folios"/>: common of one confessor not bishop;</p>
                                    <p>
                                        <locus from="296r" to="296r" scheme="folios"/>: common of one and many virgins;</p>
                                    <p/>
                                    <p/>
                                    <p>
                                        <locus from="301v" to="301v" scheme="folios"/>: common of a woman neither a virgin, nor a martyr.</p>
                                    <p/>
                                </note>
                            </msItem>
                            <msItem>
                                <locus from="301v" to="328r" scheme="folios"/>
                                <title type="desc">Votive masses</title>
                                <rubric>Incipiunt misse votive per ebdomadam et primo de sancta trinitate</rubric>
                                <incipit>Benedicta semper sancta sit</incipit>
                                <explicit>Cum sanctis tuis in eternum quia pius es</explicit>
                                <note>
                                    <p> Collection of votive masses beginning with the mass for the Trinity.</p>
                                    <p>
                                        <locus from="305r" to="310v" scheme="folios"/>: Mass of the Virgin Mary;</p>
                                    <p>
                                        <locus from="320r" to="328r" scheme="folios"/>: Masses for the dead;</p>
                                    <p>
                                        <locus from="328v" to="329v" scheme="folios"/>: ruled, but no text.</p>
                                </note>
                            </msItem>
                        </msContents>
                        <physDesc>
                            <objectDesc>
                                <supportDesc material="parchment">
                                    <support>
                                        <p>
                                            <locus from="A" to="329" scheme="folios"/>
