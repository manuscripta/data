                                            <height quantity="170" unit="mm"/>
                                            <width quantity="110" unit="mm"/>
                                        </dimensions>
                                        <note>Guidelines and ruling in ink.</note>
                                    </layout>
                                    <layout columns="1" ruledLines="14">
                                        <locus from="137" to="148" scheme="folios"/>
