                            <msItem>
                                <locus from="22r" to="37v" scheme="folios"/>
                                <title type="desc">De gradibus humilitatis</title>
                                <rubric>Incipit prologus in commentum beati bernhardi abbatis de xiii gradibus humilitatis </rubric>
                                <incipit>IN hoc opusculo cum illud quod de evangelio? dominus ait</incipit>
                                <explicit>tu in tuo corde quam in nostro codice leges Explicit Deo gracias</explicit>
                                <note>The main text is followed by two lines from the hymn <quote>Gloria laus et honor</quote> and four additional lines.</note>
                                <colophon>
                                    <locus from="37v" to="37v" scheme="folios"/>Gunthero domino claustri erffordensis alumno confrater wernherus scriptor libri fuit huius Quorum christe bone crimina tolle pie Anno milleno domini cccc<hi rend="super">o</hi> et lx<hi rend="super">o</hi>
                                </colophon>
                            </msItem>
                            <msItem>
                                <locus from="38r" to="64v" scheme="folios"/>
                                <title type="desc">Alphabetum divini amoris</title>
                                <incipit>Ad honorem omnipotentis dei aliquos modos et uias</incipit>
                                <explicit>ut sit adiutor tuus protector director et finis? Amen</explicit>
                                <finalRubric>Explicit alphabetum diuini amoris de eleuacione mentis in deum Deo gracias</finalRubric>
                                <note>The text is followed by a brief excerpt from a vita of St Anthony and a text titled <quote>De mititate et manusuetudine</quote>, in total 15 lines. </note>
                            </msItem>
                            <msItem>
                                <locus from="65r" to="71r" scheme="folios"/>
                                <title type="desc">On the eucharist</title>
                                <rubric>Quod significat transmutacio que sit in pane et vino </rubric>
                                <incipit>ET quam in isto sacramento ipse res uisibiles</incipit>
                                <explicit>ne deficerent ut possint peruenire ad suam propriam patriam </explicit>
                                <finalRubric>Explicit de sacramento eucaristie </finalRubric>
                            </msItem>
                            <msItem>
                                <locus from="74r" to="83r" scheme="folios"/>
                                <title type="desc">Tractatus de moribus infantum et adoloescentum </title>
                                <rubric>Tractatus beati bernhardi de moribus infantum et adoloescentum </rubric>
                                <incipit>HOrtatur quid timidam mentis mee impericiam</incipit>
                                <explicit>domino seruientes -im faciunt celo totisque iurbus sibi diripiunt illud ? et cetera </explicit>
                                <finalRubric>Explicit libellus beati Bernhardi abbatis pulcher de moribus infatum seu adoloscentum nomine domini? Amen </finalRubric>
                            </msItem>
                            <msItem>
                                <locus from="83r" to="92r" scheme="folios"/>
                                <title type="desc">Tractatus de proficendo </title>
                                <rubric>Sequitus tractatus optimus in seruicio dei proficere uolentibus </rubric>
                                <incipit>Si uis in spiritu proficere et hoc esse propter quod </incipit>
                                <explicit>non diligi indignum nec ullam ei reuerenciam exhiberi </explicit>
                                <finalRubric>Explicit formula -te compendiosa </finalRubric>
