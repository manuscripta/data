                                <handNote xml:id="hand-1">Hybrida. </handNote>
                            </handDesc>
                            <additions>
                                <p>
                                    <locus from="1r" to="1r" scheme="folios"/>
                                    <note>4 notes by a medieval hand. Note 2 concerns events after the Stockholm Bloodbath and begins <quote>Anno domini 1521 Martirizatus et submersus fuit venerabilis pater abbas Arwidus</quote>; note 3 begins: <quote>Anno domini 1524 dominica</quote>; note 4 begins: <quote>Anno 1526</quote>. The notes are transcribed in <bibl>
                                            <title type="short" ref="https://www.manuscripta.se/bibl/102184">DS 1</title>
                                            <citedRange from="xii" to="xiii" unit="page"/>
                                        </bibl>. </note>
                                </p>
                                <p>
                                    <locus from="1v" to="1v" scheme="folios"/>
                                    <note>Top of page, in black ink by an early modern hand: 5 lines of text beginning with <quote>liber preciosus monasterii Nydalensis</quote>.</note>
                                </p>
                                <p>
                                    <locus from="2r" to="51r" scheme="folios"/>
                                    <note>Dates from the main text written in Arabic numerals in the margin by an early modern or modern hand.</note>
                                </p>
                            </additions>
                            <decoDesc>
                                <p>Main text in black ink, capitals touched in red, occasional rubrics in red.</p>
                                <decoNote type="initials">
                                    <p>
                                        <locus from="2r" to="55v" scheme="folios"/>: plain initials over 2-3 lines in red.</p>
                                </decoNote>
