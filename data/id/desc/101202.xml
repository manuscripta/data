                            <msItem>
                                <locus from="125v" to="129v" scheme="folios"/>
                                <title type="desc">Common of virgins</title>
                                <rubric>de virginibus hore</rubric>
                                <incipit>SEpe vos fratres karissimi ammoneo</incipit>
                                <explicit>Sub tuum presidium confugimus dei genitris uirgo nostras deprecaciones Psalmus Dominus regnauit cum aliis (?) <!--regnavit baserat på parallell på 128v Dominus regnavit exultet terra  -->
                                </explicit>
                                <note>Two leaves missing between <locus from="126v" to="126v" scheme="folios"/> and <locus from="127" to="127" scheme="folios"/> resulting in loss of text.</note>
                            </msItem>
                            <msItem>
                                <locus from="130r" to="131v" scheme="folios"/>
                                <title type="desc">Readings for the Annunciation</title>
                                <rubric>de beata maria</rubric>
                                <incipit>BEata dei genitris uirgo maria</incipit>
                                <explicit>ad resurrectionis glorias perducamur Per dominus</explicit>
                                <note>
                                    <p>Seven readings excerpted from Jerome's letter no. IX to Paula and Eustochium followed by a <foreign xml:lang="la">postcommunio </foreign>for the Annunciation.</p>
                                    <p>
                                        <locus from="130r" to="130r" scheme="folios"/>: the Virgin Mary with the Christ Child and two angels.</p>
                                </note>
