                                <title type="desc">Proper of time</title>
                                <rubric>In aduentu domini ad Romanos </rubric>
                                <incipit>Fratres Scientes quia hora est</incipit>
                                <explicit>Quod autem uobis dico omnibus dico uigilate</explicit>
                                <note>The Proper of time starts with the First Sunday of Advent and ends with the Twenty-fifth Sunday after Pentecost.</note>
                            </msItem>
                            <msItem>
                                <locus from="138r" to="149v" scheme="folios"/>
                                <title type="desc">Proper of Saints</title>
                                <rubric>De sancto Panchratio et sociis eius Secundum mathevm</rubric>
                                <incipit>In illo tempore Accesserunt ad ihesum pharisei</incipit>
                                <explicit>relictis retibus et patre secuti sunt eum</explicit>
                                <note>Starts with St Pancras (12 May) and ends with the Vigil of St Andrew (29 Nov.).</note>
                            </msItem>
                            <msItem>
                                <locus from="149v" to="150v" scheme="folios"/>
                                <title type="desc">Common of saints</title>
