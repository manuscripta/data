                                <msItem>
                                    <locus from="3" to="101" scheme="pages"/>
                                    <title type="desc">Antiphons for the Office</title>
                                    <rubric>Dominica ad matutinas Inuitatorium</rubric>
                                    <incipit>Trinum deum et vnum pronis mentibus adoremus</incipit>
                                    <explicit defective="unknown">Funde preces tuo nato ihesu christo uulnerato pro nobis et flagellato spinis sputo felle potato. O dulcis Maria.</explicit>
                                </msItem>
                                <msItem>
                                    <locus from="101" to="102" scheme="pages"/>
                                    <title type="desc">Antiphons for Virgin Mary</title>
                                    <rubric>Tempore paschali post completorium antiphona</rubric>
                                    <incipit>Regina celi letare alleluya quia quem meruisti portare alleluya</incipit>
                                    <explicit>et benedictus fructus ventris tui in eternum versus alleluya</explicit>
                                    <note>Both antiphons, <quote>Regina celi leta</quote> and <quote>Ave maria</quote>, are followed by <quote>alleluya</quote>.</note>
                                </msItem>
                                <msItem>
                                    <locus from="102" to="105" scheme="pages"/>
                                    <title type="desc">Tropes for Benedicamus Domino</title>
                                    <rubric>Inter pascha et pen<supplied reason="omitted" xml:lang="la">tecosten</supplied>
                                    </rubric>
                                    <incipit>Benedicamus virginis filio alleluya alleluya alleluya</incipit>
                                    <explicit>Benedicamus domino alleluya. Deo gracias alleluya.</explicit>
                                </msItem>
                                <msItem>
                                    <locus from="106" to="121" scheme="pages"/>
                                    <title type="desc">Hymns</title>
                                    <rubric>In dominica ad matutinas super nocturnam ymnus</rubric>
                                    <incipit>O Trinitatis gloria celestis decus curie sponsa regis altissimi</incipit>
                                    <explicit>trinum deum glorificet pro te tam digna laudibus Maria mater gracie Gloria tibi domino.</explicit>
                                    <listBibl>
                                        <bibl>
                                            <title type="short" ref="https://www.manuscripta.se/bibl/107283">AH 48</title>
                                            <citedRange from="362" to="388" unit="number"/>
                                        </bibl>
                                        <bibl>
                                            <title type="short" ref="https://www.manuscripta.se/bibl/107284">AH 51</title>
                                            <citedRange from="123" to="123" unit="number"/>
                                            <citedRange from="125" to="126" unit="number"/>
                                        </bibl>
                                        <bibl>
                                            <title type="short" ref="https://www.manuscripta.se/bibl/107285">AH 27</title>
                                            <citedRange from="82" to="82" unit="number"/>
                                        </bibl>
                                        <bibl>
                                            <title type="short" ref="https://www.manuscripta.se/bibl/107286">AH 50</title>
                                            <citedRange from="71" to="72" unit="number"/>
                                        </bibl>
                                        <bibl>
                                            <title type="short" ref="https://www.manuscripta.se/bibl/107289">AH 32</title>
                                            <citedRange from="130" to="130" unit="number"/>
                                        </bibl>
                                    </listBibl>
                                </msItem>
                                <msItem>
                                    <locus from="121" to="122" scheme="pages"/>
                                    <title type="desc" xml:lang="la">Suffrages for St Birgitta</title>
                                    <incipit xml:lang="la">Rosa rorans bonitatem stella stillans claritatem</incipit>
                                    <explicit>Domine deus noster qui secundum magnam misericordiam tuam beate Birgitte tantam dedisti gratiam <gap quantity="5" unit="lines" reason="editorial"/> et regnat in unitate spiritus sancti deus. Per omnia secula seculorum. Amen. Versus. Domine exaudi orationem meam. Responsorium. Et clamor meus ad te ueniat et cetera</explicit>
                                    <note>The two antiphons, <quote xml:lang="la">Rosa rorans</quote> and <quote xml:lang="la">Gaude Birgitta</quote>, are set to music but in reverse order from Geete's edition. The collect following <quote>Rosa rorans</quote> is in Geete placed after <quote>Gaude Birgitta</quote>. The collect following the latter is not in Geete.</note>
                                </msItem>
                                <bibl>
