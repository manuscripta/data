                                    <rubric xml:lang="la">Michaelis</rubric>
                                    <incipit xml:lang="la">Deus cuius claritatis fulgore beatus michael</incipit>
                                    <explicit xml:lang="la">ut cuius gloriam predicamus in terris ipsius precibus adiuuemur in celis. per.</explicit>
                                    <listBibl>
