                                <title type="desc">Hours of the Virgin</title>
                                <rubric>Incipit officium beate Marie Virginis </rubric>
                                <incipit>Ad matutinum Antiphonas DOMINE Labia mea aperies <gap reason="editorial"/> Inuitatorium Aue marie gracia plena </incipit>
                                <explicit>Resurrexit sicut dixit alleluya Ora pro nobis deum alleluya</explicit>
                            </msItem>
                            <msItem>
