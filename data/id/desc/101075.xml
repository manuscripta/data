                        <msContents>
                            <textLang mainLang="la"/>
                            <msItem>
                                <locus from="11ra" to="136va" scheme="folios"/>
                                <title type="desc">Proper of time</title>
                                <rubric>dominica prima <sic>prima</sic> in aduentus</rubric>
                                <incipit>AD te leuaui animam meam </incipit>
                                <explicit defective="false">Ite missa alleluia alleluia alleluia</explicit>
                                <note>
                                    <p>
                                        The Proper of time begins with the First Sunday of Advent and the first part ends with Holy Saturday. The Proper of time is continued after the Ordo and Canon missae.</p>
                                    <p/>
                                    <p/>
                                    <p/>
                                    <p/>
                                    <p>
                                        <locus from="S34Av" to="S34Av" scheme="folios"/> is a parchment slip measuring ca 80x60 mm. It carries text on the verso with a signe-de-renvoi refering to text on <locus from="35ra" to="35ra" scheme="folios"/>. The leaves <locus from="123a" to="123a" scheme="folios"/> and <locus from="292" to="292" scheme="folios"/> are also parchment slips of a similar size and function.</p>
                                    <p/>
                                    <p>
                                        <locusGrp>
                                            <locus from="11A" to="11A" scheme="folios"/>
                                            <locus from="18A" to="18A" scheme="folios"/>
                                            <locus from="21A" to="21A" scheme="folios"/>
                                            <locus from="28A" to="28A" scheme="folios"/>
                                            <locus from="51A" to="51A" scheme="folios"/>
                                            <locus from="53A" to="53A" scheme="folios"/>
                                            <locus from="54A" to="54A" scheme="folios"/>
                                            <locus from="60A" to="60A" scheme="folios"/>
                                            <locus from="67A" to="67A" scheme="folios"/>
                                            <locus from="72A" to="72A" scheme="folios"/>
                                            <locus from="75A" to="75A" scheme="folios"/>
                                            <locus from="103A" to="103A" scheme="folios"/>
                                            <locus from="108A" to="108A" scheme="folios"/>
                                            <locus from="131A" to="131A" scheme="folios"/>
                                            <locus from="135A" to="135A" scheme="folios"/>
                                        </locusGrp>: dummy leaves inserted.</p>
                                    <p/>
                                    <p/>
                                    <p/>
                                </note>
                            </msItem>
                            <msItem>
                                <locus from="136va" to="140rb" scheme="folios"/>
                                <title type="desc">Ordo and Canon missae</title>
                                <rubric>de beata virgine glorificaciones</rubric>
                                <incipit>Gloria in excelsis deo</incipit>
                                <explicit>et per te incepta finiatur Per christum</explicit>
                                <note>
                                    <p>
                                        Canon image and most of the the Ordo and Canon missae missing because of a lost quire. The last rubric on <locus from="137v" to="137v" scheme="folios"/> is <quote>benediccio aque</quote>. After this a singleton and an entire quire would have followed, but these are now lost; the first rubric on <locus from="138r" to="138r" scheme="folios"/> is <quote>hic leuat manus sursum dicans</quote>.</p>
                                    <p>
                                        <locus from="137A" to="137B" scheme="folios"/>: dummy leaves inserted.</p>
                                </note>
                            </msItem>
                            <msItem>
                                <locus from="140rb" to="204rb" scheme="folios"/>
                                <title type="desc">Proper of time (continued)</title>
                                <rubric>In die resureccionis domini </rubric>
                                <incipit>Resurrexi et adhuc tecum</incipit>
                                <explicit>tue medicacionis dono curetur per domino</explicit>
                                <note>
                                    <p>
                                        The Proper of time continues with Easter Sunday and ends with the Twenty-fifth Sunday after Trinity.</p>
                                    <p>
                                        <locusGrp>
                                            <locus from="149A" to="149A" scheme="folios"/>
                                            <locus from="157A" to="157B" scheme="folios"/>
                                            <locus from="159A" to="159A" scheme="folios"/>
                                            <locus from="166A" to="166A" scheme="folios"/>
                                            <locus from="169A" to="169A" scheme="folios"/>
                                            <locus from="176A" to="176A" scheme="folios"/>
                                        </locusGrp>: dummy leaves inserted. Text missing after <locus from="157" to="157" scheme="folios"/> (one leaf).</p>
                                </note>
                            </msItem>
                            <msItem>
                                <locus from="204rb" to="205va" scheme="folios"/>
                                <title type="desc">Dedication of the church</title>
                                <rubric>In dedicacione</rubric>
                                <incipit>TErribilis est locus iste</incipit>
                                <explicit defective="unknown">te ducente peruenire mereatur Per dominum nostrum</explicit>
                            </msItem>
                            <msItem>
                                <locus from="205va" to="207vb" scheme="folios"/>
                                <title type="desc">Mass of the Five Wounds</title>
                                <rubric>de quinque wlneribus officium </rubric>
                                <incipit>Hvmiliauit semet ipsum </incipit>
                                <explicit>paradysi ianuas gaudiaque eterna introire mereamur Qui vnus</explicit>
                            </msItem>
                            <msItem>
                                <locus from="208ra" to="269vb" scheme="folios"/>
                                <title type="desc">Proper of saints</title>
                                <rubric>In vigilia sancti Andree apostoli </rubric>
                                <incipit>Deus secus mare galylee vidit duos fratres (Matt. 4:18)</incipit>
                                <explicit>saturnini tibi reddat acceptos</explicit>
                                <note>
                                    <p>
                                        The Proper of saints begins with the vigil for Saint Andrew (29 November) and ends with Saint Saturnin (29 November).</p>
                                    <p>
                                        <locus from="218rb" to="218rb" scheme="folios"/>: St Henrik;</p>
                                    <p>
                                        <locus from="219va" to="219va" scheme="folios"/>: St Erik with translation;</p>
                                    <p>
                                        <locus from="226rb" to="226rb" scheme="folios"/>: St Sigfrid;</p>
                                    <p>
                                        <locus from="234vb" to="234vb" scheme="folios"/>: St Gangulphus;</p>
                                    <p/>
                                    <p>
                                        <locus from="235vb" to="235vb" scheme="folios"/>: St Eskil;</p>
                                    <p>
                                        <locus from="236va" to="236va" scheme="folios"/>: St Botulf;</p>
                                    <p/>
                                    <p>
                                        <locus from="244ra" to="244ra" scheme="folios"/>: St David;</p>
                                    <p>
                                        <locus from="247va" to="247va" scheme="folios"/>: St Botvid;</p>
                                    <p>
                                        <locus from="247vb" to="247vb" scheme="folios"/>: St Olof;</p>
                                    <p>
                                        <locus from="249ra" to="249ra" scheme="folios"/>: St Elin;</p>
                                    <p/>
                                    <p>
                                        <locus from="263rb" to="263rb" scheme="folios"/>: St Birgitta.</p>
                                    <p>
                                        <locus from="234A" to="234A" scheme="folios"/>, <locus from="240A" to="240A" scheme="folios"/>: dummy leaves inserted.</p>
                                    <p/>
                                    <p/>
                                </note>
                            </msItem>
                            <msItem>
                                <locus from="269vb" to="294va" scheme="folios"/>
                                <title type="desc">Common of saints</title>
                                <rubric>In vigilia vnius apostoli</rubric>
                                <incipit>Ego autem sicut oliua (Ps. 51:10)</incipit>
                                <explicit>virginis tue intercessio veneranda</explicit>
                                <note>
                                    <p>
                                        <locus from="269vb" to="269vb" scheme="folios"/>: Common of one apostle;</p>
                                    <p>
                                        <locus from="273vb" to="273vb" scheme="folios"/>: Common of one martyr;</p>
                                    <p>
                                        <locus from="277vb" to="277vb" scheme="folios"/>: Common of martyrs;</p>
                                    <p>
                                        <locus from="284va" to="284va" scheme="folios"/>: Common of confessors;</p>
                                    <p>
                                        <locus from="290va" to="290va" scheme="folios"/>: Common of one virgin.</p>
                                </note>
                            </msItem>
                            <msItem>
                                <locus from="294va" to="298vb" scheme="folios"/>
                                <title type="desc">Votive masses</title>
                                <rubric>Incipiunt misse votiue et primo de sancta trinitate</rubric>
                                <incipit>Benedicta sit sancta trinitas</incipit>
                                <explicit defective="true">et usque ad futurum</explicit>
                                <note>
                                    <p>
                                        Votive masses of the Holy Trinity, the Holy Spirit and the Holy Cross.</p>
                                    <p>
                                        <locus from="296vb" to="298vb" scheme="folios"/>: Mass of the Virgin Mary. The text ends in an incomplete mass for Ascension to Advent, and Candlemas to Easter.</p>
