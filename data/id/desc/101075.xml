                        <msContents>
                            <textLang mainLang="la"/>
                            <msItem>
                                <locus from="1r" to="1r" scheme="folios"/>
                                <title type="desc">Mnemonic verses and prayers</title>
                                <note>The text consists of some mnemonic verses, collect prayers and a distich. See <bibl>
                                        <title type="short" ref="https://www.manuscripta.se/bibl/107364">Frithz (1976)</title>
                                        <citedRange from="29" to="29" unit="page"/>
                                        <citedRange from="25" to="26" unit="footnote"/>
                                    </bibl>. On the distichon, see <bibl>
                                        <title type="short" ref="https://www.manuscripta.se/bibl/101544">Walther (1963–1986)</title>
                                        <citedRange from="2786" to="2786" unit="page"/>
                                    </bibl>. See Additions for the the text below the prayers and <locus from="1v" to="1v" scheme="folios"/>.</note>
                            </msItem>
                            <msItem>
                                <locus from="2r" to="7v" scheme="folios"/>
                                <title type="desc">Calendar</title>
                                <note>
                                    <p>
                                        Notable feasts:</p>
                                    <p>
                                        <locus from="2r" to="2r" scheme="folios"/>: Henrik (19 Jan.);</p>
                                    <p>
                                        <locus from="2v" to="2v" scheme="folios"/>: Sigfrid (15 Feb.);</p>
                                    <p>
                                        <locus from="3v" to="3v" scheme="folios"/>: Helena (5 Apr.);</p>
                                    <p>
                                        <locus from="4r" to="4r" scheme="folios"/>: Gangulphus (11 May);</p>
                                    <p>
                                        Erik (18 May);</p>
                                    <p>
                                        <locus from="4v" to="4v" scheme="folios"/>: Eskil (12 Jun.);</p>
                                    <p>
                                        Botulf (17 Jun.);</p>
                                    <p>
                                        <locus from="5r" to="5r" scheme="folios"/>: David (15 July, contemporary addition);</p>
                                    <p>
                                        Botvid (28 Jul.);</p>
                                    <p>
                                        Olof (29 Jul.);</p>
                                    <p>
                                        Elin (31 Jul.);</p>
                                    <p>
                                        <locus from="6v" to="6v" scheme="folios"/>: Birgitta (7 Oct.).</p>
                                    <p>
                                        Regarding the veneration of Saint Gangulphus in Stockholm, see <bibl>
                                            <title type="short" ref="https://www.manuscripta.se/bibl/107364">Frithz (1976)</title>
                                            <citedRange from="70" to="70" unit="page"/>
                                        </bibl>.</p>
                                    <p/>
                                </note>
                            </msItem>
                            <msItem>
                                <locus from="8v" to="10r" scheme="folios"/>
                                <title type="desc">Blessing of salt and water</title>
                                <rubric>Exorcismus salis et aque</rubric>
                                <incipit>
                                    <sic>Exorzizo</sic> te creatura salis per deum </incipit>
                                <explicit defective="false">defendat omnes habitantes in hoc habitaculo Per christum dominum nostrum Amen</explicit>
                            </msItem>
                            <msItem>
                                <locus from="10va" to="10vb" scheme="folios"/>
                                <title type="desc">Reading from Luke</title>
                                <rubric>lucam</rubric>
                                <incipit>In illis Ibat ihesus in ciuitatem que vocatur naym (Luke 7:11)</incipit>
                                <explicit defective="unknown">in nobis et quia deus uisitauit plebem suam (Luke 7:16)</explicit>
                            </msItem>
                        </msContents>
