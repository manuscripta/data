                                <title type="desc">Historia sanctorum</title>
                                <msItem>
                                    <locus from="2r" to="7v" scheme="folios"/>
                                    <title type="desc">Office for St Henrik (20 Jan.)</title>
                                    <rubric>Henrici Canta Laudes hystoria sancta</rubric>
                                    <incipit>Gaude cetus fidelium Henrici natalicium </incipit>
                                    <explicit>gaudet cetus fidelium Amen</explicit>
                                    <finalRubric>Explicit hic cantus henrici dummodo tantus </finalRubric>
                                    <note>
                                        <p>
                                            <locus from="7" to="7" scheme="folios"/>: Translation of St Henrik.</p>
                                        <p/>
                                    </note>
                                    <bibl>
                                        <title type="short" ref="https://www.manuscripta.se/bibl/107600">Heikkilä (2009)</title>
                                        <citedRange from="254" to="274" unit="page"/>
                                    </bibl>
                                </msItem>
                                <msItem>
                                    <locus from="8r" to="11v" scheme="folios"/>
                                    <title type="desc">Office for St Erik (18 May)</title>
                                    <rubric>Historia De Sancto Erico martire et rege</rubric>
                                    <incipit>Assunt erici regis solennia laude regem </incipit>
                                    <explicit>nobis placa martir bone ihesum dei filium alleluia</explicit>
                                    <note>
                                        <locus from="8r" to="8r" scheme="folios"/>, bottom margin: a distich in hexameter in red: <quote>Presul et Henricus servant nos sanctus Ericus / Sic fugit iniqus hos diligit omnis amicus</quote>. </note>
                                </msItem>
                                <msItem>
                                    <locus from="11r" to="13v" scheme="folios"/>
                                    <title type="desc">Office for St Erasmus (3 June)</title>
                                    <rubric>De Sancto Erasmo </rubric>
                                    <incipit>Oracio Da nobis quesumus omnipotens deus Vt quyi beati erasmi</incipit>
                                    <explicit>a sancti angelis cum gloria in secula seculorum Amen Tu</explicit>
                                </msItem>
                                <msItem>
                                    <locus from="14r" to="18v" scheme="folios"/>
                                    <title type="desc">Office for St Eskil (12 June)</title>
                                    <rubric>De sancto Eskillo </rubric>
                                    <incipit>Oracio antiphona supra psalmum Letabitur Responsorium O proles britanie </incipit>
                                    <explicit>tue sis familie dulcis Consolator Amen </explicit>
                                    <finalRubric>hic finitur historia beati Eskilli </finalRubric>
                                </msItem>
                                <msItem>
                                    <locus from="18v" to="20v" scheme="folios"/>
                                    <title type="desc">Office for St Sunniva (8 July)</title>
                                    <rubric>In festo Sancte suniue virginis et martiris sociorum eius  </rubric>
                                    <incipit>Svpplicacionibus nostris quesumus omnipotens deus </incipit>
                                    <explicit>cui est honor et gloria in secula Seculorum Amen </explicit>
                                </msItem>
                                <msItem>
                                    <locus from="20v" to="24r" scheme="folios"/>
                                    <title type="desc">Office for St Elin of Skövde (31 July)</title>
                                    <rubric>Hystoria de Sancta Helena </rubric>
                                    <incipit>Capitulum militem fortem FElix parens vesgocia </incipit>
                                    <explicit>vivamus eterna Magnificat anima Mea dominum</explicit>
                                </msItem>
                                <msItem>
                                    <locus from="24v" to="27r" scheme="folios"/>
                                    <title type="desc">Office for St Barbara (4 Dec.)</title>
                                    <rubric>De Sancta Barbara</rubric>
                                    <incipit>Capitulum Confitebeor Optaui et datus est michi <add place="above">sensus</add>
                                    </incipit>
                                    <explicit>atque saluatore nostro ihesu christo in secula seculorum Amen</explicit>
                                </msItem>
                                <msItem>
                                    <locus from="27r" to="29r" scheme="folios"/>
                                    <title type="desc">Presentation of the Blessed Virgin Mary (21 Nov.)</title>
                                    <rubric>In festo presentacionis Sanctissime virgine marie </rubric>
                                    <incipit>Expedit fidelium deuocioni beatissime virginis marie</incipit>
                                    <explicit>et post hanc fragilem vitam felicitatem eternam nobis prestare dignetur Tu autem antiphona Deo gracias</explicit>
                                </msItem>
                                <msItem>
                                    <locus from="29r" to="30v" scheme="folios"/>
                                    <title type="desc">Office for St Knut (7 Jan.)</title>
                                    <rubric>kanuto Die Sancto kanuto rege et martire</rubric>
                                    <incipit>oracio Deus qui Beatum kanutum regem </incipit>
                                    <explicit>de quibus longum est per singula enarrare Tu autem</explicit>
                                </msItem>
                                <msItem>
                                    <locus from="30v" to="33v" scheme="folios"/>
                                    <title type="desc">Office for St Ansgar (4 Feb.)</title>
                                    <rubric>In festo Sancti ansgarii episcopi et confessoris</rubric>
                                    <incipit>Deus qui populo tuo eterne salutis beatum ansgarium</incipit>
                                    <explicit>per tres menses continuo infirmatus Die Beati blasii quieuit in pace Tu autem Domine</explicit>
                                </msItem>
                                <msItem>
                                    <locus from="33v" to="34v" scheme="folios"/>
                                    <title type="desc">Office for St Dorothea (6 Feb.)</title>
                                    <rubric>De Sancta dorothea </rubric>
                                    <incipit>Oracio Omnipotens sempiterne deus in cuius nomine gloriosa virgo et martir dorothea</incipit>
                                    <explicit>Sic quod theophilus ad christum perrexit Tu</explicit>
                                </msItem>
                                <msItem>
                                    <locus from="34v" to="36r" scheme="folios"/>
                                    <title type="desc">Office for St Simeon (9 Feb.)</title>
                                    <rubric>Die Sancto Symeone </rubric>
                                    <incipit>Collecta collecta PErfice in nobis quesumus Domine graciam tuam qui iusti Symeonis exspectacionem implesti</incipit>
                                    <explicit>ipsum quem genuit adorauit </explicit>
                                    <finalRubric>Cetera omnia Sicut in communi vnius confessoris</finalRubric>
                                </msItem>
                                <msItem>
                                    <locus from="36v" to="40r" scheme="folios"/>
                                    <title type="desc">Office for St Sigfrid (15 Feb.)</title>
                                    <rubric>De sancto Sigfrido </rubric>
                                    <incipit>Antiphona SAnctus sigfridus anglie Ortus  </incipit>
                                    <explicit>sine terminacione tecum celi mansione Magnificat anima mea dominum </explicit>
                                </msItem>
                                <msItem>
                                    <locus from="40r" to="41r" scheme="folios"/>
                                    <title type="desc">Office for St Gertrude (17 Mar.)</title>
                                    <rubric>De sancta Gertrude </rubric>
                                    <incipit>Oracio Deus qui Beatam Gertrudem Virginem </incipit>
                                    <explicit>Cuius animama sancti angeli ad celestia gaudia detulerant Tu autem Deo Gracias</explicit>
                                    <note>
                                        <locus from="41r" to="41r" scheme="folios"/> Below the main text: <quote>A baratri pena salua nos virgo serena</quote>.</note>
                                </msItem>
                                <msItem>
                                    <locus from="41v" to="44r" scheme="folios"/>
                                    <title type="desc">Compassio Mariae</title>
                                    <rubric>Historia  De Compassione Beate marie virginis </rubric>
                                    <incipit>STabat virgo dolorosa mater christi generosa</incipit>
                                    <explicit>nobis donet sine fine perfrui leticia alleluia Magnificat anima</explicit>
                                </msItem>
                                <msItem>
                                    <locus from="44v" to="49r" scheme="folios"/>
                                    <title type="desc">Office for the Patron Saints of Sweden (3-9 July)</title>
                                    <rubric>hystoria de sanctissimis patronis </rubric>
                                    <incipit>IOcundare mater ecclesia noue lucis agens solennia </incipit>
                                    <explicit>In qua semper gloriantur beatorum anime psalmus Magnificat anima </explicit>
                                </msItem>
                                <msItem>
                                    <locus from="49r" to="49r" scheme="folios"/>
                                    <title type="desc">Office for St Birgitta (23 July)</title>
                                    <rubric>In festo Sancte Birgitte</rubric>
                                    <incipit>Rosa rorans bonitatem </incipit>
                                    <explicit>Signum magnum appar<add place="above">v</add>it amicta sole femina solem</explicit>
                                    <note> imperfect;</note>
                                </msItem>
                                <msItem>
                                    <locus from="49v" to="53r" scheme="folios"/>
                                    <title type="desc">Office for St Christoffer (25 July)</title>
                                    <rubric>De sancto christofero legenda</rubric>
                                    <incipit>Oracio Omnipotens sempiterne Deus fortitudo constantium </incipit>
                                    <explicit>ut si quis deum aut christoforum blasphemaret continuo gladio feriretur Tu autem </explicit>
                                    <finalRubric>finiunt lecciones De sancto christofero </finalRubric>
                                </msItem>
                                <bibl>
                                    <title type="short" ref="https://www.manuscripta.se/bibl/101007">Maliniemi (1957)</title>
                                    <citedRange from="39" to="184" unit="page"/>
                                </bibl>
                            </msItem>
                        </msContents>
