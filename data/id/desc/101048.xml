                                    <title type="desc">On the resurrection</title>
                                    <incipit>de resurrectione queritur si est</incipit>
                                    <explicit>fiet eorum resurrectio naturalis quia ordinata finalis quia amata foris quia considerata </explicit>
                                </msItem>
                                <msItem>
                                    <locus from="230ra" to="230rb" scheme="folios"/>
                                    <title type="desc">On offerings</title>
                                    <incipit>queritur utrum omnes teneantur facere sacrificia</incipit>
                                </msItem>
                                <msItem>
                                    <locus from="231r" to="231r" scheme="folios"/>
                                    <title type="desc">On temperance</title>
                                    <incipit>de temperantia queritur primo quid sit</incipit>
                                    <explicit>Respondeoo non sequitur quia non ponitur ibi finis sed ulterius ordinatur in <unclear quantity="2" unit="chars"/>
                                    </explicit>
                                </msItem>
                                <msItem>
                                    <locus from="230v" to="231r" scheme="folios"/>
                                    <title type="desc">On modesty</title>
                                    <incipit>queritur de modestia primo quid sit</incipit>
                                    <explicit defective="true">Item ad modestiam vel </explicit>
                                    <note>The quodlibetum begins on <locus from="231r" to="231r" scheme="folios"/> and continues on the lower third of <locus from="230v" to="230v" scheme="folios"/> with the end missing due to trimming.</note>
                                </msItem>
                                <msItem>
                                    <locus from="231v" to="231v" scheme="folios"/>
                                    <title type="desc">On conjugal and virginal continence</title>
                                    <incipit>i co vii non peccat uirgo si nubat</incipit>
                                    <explicit>quiquid inter se coniugati inuerecunde immodeste et sordide gerunt uicium est hominum non nuptiarum</explicit>
                                </msItem>
                                <bibl>
