                            <msItem>
                                <locus from="8va" to="230vb" scheme="folios"/>
                                <author>
                                    <persName ref="https://www.manuscripta.se/person/102611"> Hugh of Saint-Cher </persName>
                                </author>
                                <title type="desc">Commentary on Peter Lombard's Sentences (abridged)</title>
                                <incipit>ultra uires contra en<unclear quantity="2" unit="chars" reason="illegible"/>cus dicit quod potes id tempta et cetera</incipit>
                                <explicit>Videbit nihilominus homo peccata sua ad deum laudandum Vnde gregorius quomodo misericordias domini in eternum cantat qui se fuisse miserum ignorat</explicit>
                                <finalRubric>Explicit opus Fratris Hugonis super Sentenciis</finalRubric>
                                <note>
                                    <p>Hugh's commentary was identified by <bibl>
                                            <title type="short" ref="https://www.manuscripta.se/bibl/107303">Stegmüller (1948)</title>
                                        </bibl> as a first redaction, but has been shown by <bibl>
                                            <title type="short" ref="https://www.manuscripta.se/bibl/107312">Principe (1963)</title>
                                        </bibl> to be an abridgement.</p>
                                    <p>Principe identifies a few of the questions in the lower margins as coming from <persName ref="https://www.manuscripta.se/person/102613">William of Auxerre's </persName> Summa Aurea (<bibl>
                                            <title type="short" ref="https://www.manuscripta.se/bibl/107312">Principe (1963)</title>
                                            <citedRange from="376" to="376" unit="page"/>
                                        </bibl>), e.g. <locus from="126v" to="126v" scheme="folios"/>, <locus from="128v" to="128v" scheme="folios"/>, and <locus from="146r" to="146r" scheme="folios"/>.</p>
                                    <p/>
                                </note>
