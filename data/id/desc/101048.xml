                                    <title type="desc">Book IV</title>
                                </msItem>
                                <incipit>Cupientes aliquid de penuria ac tenuitate</incipit>
                                <explicit>per media ad pedes usque uia duce peruenit</explicit>
                                <bibl>
                                    <title type="short" ref="https://www.manuscripta.se/bibl/107238">Patrologia Latina</title>
                                    <citedRange from="192" to="192" unit="volume"/>
                                    <citedRange from="521" to="962" unit="column"/>
