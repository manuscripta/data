                            <msItem>
                                <locus from="2ra" to="2va" scheme="folios"/>
                                <author>
                                    <persName ref="https://www.manuscripta.se/person/102682"> Thomas Ebendorfer von Haselbach </persName>
                                </author>
                                <title type="desc">Prologue</title>
                                <incipit>Crebro multa sollicitudine dum in minoribus </incipit>
                                <explicit>Ideo ut cicius querenti occurrat ad nota quesitum tabulam oportuit secundum ordinem foliorum premittere</explicit>
                                <note>
                                    <locus from="1" to="1" scheme="folios"/>, <locus from="3r" to="3r" scheme="folios"/>: guidelines, no text.</note>
                            </msItem>
                            <msItem>
                                <locus from="3va" to="240vb" scheme="folios"/>
                                <author>
                                    <persName ref="https://www.manuscripta.se/person/102682"> Thomas Ebendorfer von Haselbach </persName>
                                </author>
                                <title type="desc">Sermons for Advent to Lent</title>
                                <rubric>Sermo primus</rubric>
                                <incipit>CVm appropinquasset Ihesus Ierosolimis (Luke 19:29) <gap reason="editorial"/> hodie sancta mater eccelsia incipit celebrare aduentum domini </incipit>
                                <explicit>Et similiter si mens? ex magna desertacione finaliter</explicit>
                                <finalRubric>
                                    <del>sequitur ... et cetera</del>
                                </finalRubric>
                                <note>
                                    <p>
                                        Begins with the First Sunday in Advent, ends with first Sunday of Lent, on <locus from="221rb" to="240vb" scheme="folios"/> follows a sermon on fasting. The text contains two rubrics that mention dates:</p>
                                    <p>
                                        <locus from="39ra" to="39ra" scheme="folios"/>: <quote>Secuntur sermones de dominica quarta aduentus domini nostri ihesu christi 1447</quote>;</p>
                                    <p>
                                        <locus from="145vb" to="145vb" scheme="folios"/>: <quote>Dominica tercia post octauas epiphanie domini 1448</quote>.</p>
                                    <p>
                                        <locus from="62" to="62" scheme="folios"/>: guidelines and running titles, but no text.</p>
                                </note>
                            </msItem>
                            <msItem>
                                <locus from="240vb" to="287rb" scheme="folios"/>
                                <author>
                                    <persName ref="https://www.manuscripta.se/person/102682"> Thomas Ebendorfer von Haselbach </persName>
                                </author>
                                <title type="desc">Treatise on penance</title>
                                <rubric>Sequitur nunc consequenter tractatus de tribus partibus penitencie honorandi domini doctoris magistri thome de haselpach scilicet de contricione confessione et satisfaccione necnon et de restitucione Et primo de contricione Et quoniam homo debeat conteri de suis peccatis </rubric>
                                <incipit>Quia ut ayt Ambrosius in sermone de ? Ecce nunc tempus acceptabile adest</incipit>
                                <explicit>Boni uiri precipue ad impensas in medicos</explicit>
                                <finalRubric>sequitur sermo dominica 2<hi rend="super">a</hi> quadragesime reminiscere</finalRubric>
                                <note>
                                    <p>
                                        <locus from="240va" to="240va" scheme="folios"/>: <quote>de contritione</quote>;</p>
                                    <p>
                                        <locus from="250rb" to="250rb" scheme="folios"/>: <quote>de confessione</quote>;</p>
                                    <p>
                                        <locus from="255rb" to="255rb" scheme="folios"/>: <quote>de satisfactione</quote>;</p>
                                    <p>
                                        <locus from="265rb" to="265rb" scheme="folios"/>: <quote>de restitutione</quote>.</p>
                                    <p>
                                        <locus from="270va" to="275rb" scheme="folios"/>: <quote>de rapina</quote> (sub-category to <quote>de restitutione</quote>).</p>
                                </note>
                            </msItem>
                            <msItem>
                                <locus from="287rb" to="491vb" scheme="folios"/>
                                <title type="desc">Sermons for Lent to Ascension</title>
                                <rubric>Sequitur nunc ulterius sermo de dominica secunda in quadragesima scilicet Reminiscere Et cetera stephanus zyricher de potendorff</rubric>
                                <incipit>EGressus Ihesus secessit (Mat. 15:21) <gap reason="editorial"/> inter cetera que reconciliant peccatorem deo</incipit>
                                <explicit>ut oportet assistere coram eo de istis et pluribus aliis uide in simone dominice secunde post pascha Rogatus</explicit>
                                <finalRubric>Sequitur nunc pars estiualis Et tamen de parte yemali 14</finalRubric>
                                <note>
                                    <p>
                                        Begins with the Second Week of Lent and ends with the Sunday in the Octave of Ascension. The first rubric mentions <persName ref="https://www.manuscripta.se/person/102755">stephanus zyricher de potendorff</persName>, potentially as the author or editor of the text. The text contains one rubric that mentions a date:</p>
                                    <p/>
                                    <p>
                                        <locus from="393rb" to="393rb" scheme="folios"/>: <quote>Sermo in die festo pashe primus 1448</quote>.</p>
                                    <p>
                                        <locus from="492" to="503" scheme="folios"/>: guidelines, but no text.</p>
                                    <p/>
                                </note>
                            </msItem>
                        </msContents>
