                            <handDesc>
                                <handNote xml:id="hand-1">Semihybrida. </handNote>
                            </handDesc>
                            <additions>
                                <p>
                                    <locus from="2r" to="472r" scheme="folios"/>
                                    <note>Scattered interlinear and marginal additions. The majority seems to be corrections by the scribe or a contemporary hand.</note>
                                </p>
                                <p>
                                    <locusGrp>
                                        <locus from="Fragment_Ar" to="Fragment_Av" scheme="folios"/>
                                        <locus from="Fragment_Br" to="Fragment_Bv" scheme="folios"/>
                                        <locus from="Fragment_Cr" to="Fragment_Cv" scheme="folios"/>
                                        <locus from="Fragment_Dr" to="Fragment_Dv" scheme="folios"/>
                                        <locus from="Fragment_Er" to="Fragment_Ev" scheme="folios"/>
                                        <locus from="Fragment_Fr" to="Fragment_Fv" scheme="folios"/>
                                        <locus from="Fragment_Gr" to="Fragment_Gv" scheme="folios"/>
                                        <locus from="Fragment_Hr" to="Fragment_Hv" scheme="folios"/>
                                    </locusGrp>
                                    <note>Fragments A-C are still placed between leaves in the manuscript. Small pieces seemingly cut from a manuscript. <locus from="Fragment_B" to="Fragment_B" scheme="other"/> contains text in German. Fragments D-H have been removed and placed in an envelope. Somewhat larger than the first three fragments. <locus from="Fragment_D" to="Fragment_D" scheme="other"/>, <locus from="Fragment_F" to="Fragment_F" scheme="other"/> and <locus from="Fragment_G" to="Fragment_G" scheme="other"/> contain text in German. <locus from="Note_1r" to="Note_1r" scheme="other"/> contains information in Swedish and partial transcritpions of some of the fragments.</note>
                                </p>
                            </additions>
                            <decoDesc>
                                <p>Main text in brown ink, rubrics in red, capitals touched in red.</p>
                                <decoNote type="initials">
                                    <p>
                                        <locus from="3va" to="489rb" scheme="folios"/>: penwork initial over 4-7 lines alternating in blue and red.</p>
                                </decoNote>
                                <decoNote type="edges">
                                    <p>
                                        <locus from="Tail" to="Tail" scheme="other"/>:<quote> Sermones honorabilis domini doctoris magistri thome de haselpach super</quote>; <locus from="Fore-edge" to="Fore-edge" scheme="other"/>: <quote>ewangelia dominicalia per yiemem</quote>; <locus from="Head" to="Head" scheme="other"/>: two lines of illegible text.</p>
                                </decoNote>
