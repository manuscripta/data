                            <msItem>
                                <locus from="3ra" to="67vb" scheme="folios"/>
                                <title type="desc">Commentary on Acts of the Apostles</title>
                                <rubric>Incipit postilla super actus apostolorum <sic>apostolorum</sic>
                                </rubric>
                                <incipit>REpleti sunt omnes (Acts 2:4) <gap reason="editorial"/> Sicut lex euuangelica per christum deum et hominem fuit data</incipit>
                                <explicit>ad quam nos perducat qui cum patre et spiritu sancto viuit <supplied reason="omitted">et</supplied> cetera</explicit>
                                <finalRubric>Explicit postilla fratris N<supplied reason="omitted">icholai</supplied> de lira Sequitur actus apostolorum incipit eadem sequitur epistolas canonicas</finalRubric>
                                <note>
                                    <bibl>
                                        <title type="short" ref="https://www.manuscripta.se/bibl/107105">RB</title>
                                        <citedRange from="5901" to="5901" unit="number"/>
                                    </bibl>.</note>
                            </msItem>
                            <msItem>
                                <locus from="68ra" to="114vb" scheme="folios"/>
                                <title type="desc">Commentary on the Catholic epistles</title>
                                <rubric>Incipit Rubrica in canonicales epistolas</rubric>
                                <incipit>Quatuor sunt minima terre (Prov. 30:24) <gap reason="editorial"/> Septem epistole que canonice id est Regulares nuncupantur</incipit>
                                <explicit>temporales tamen virtus diuina qua facit est eterna Amen</explicit>
                                <finalRubric>Sequitur apocalipsis et cetera </finalRubric>
                                <note>
                                    <p>
                                        <bibl>
                                            <title type="short" ref="https://www.manuscripta.se/bibl/107105">RB</title>
                                            <citedRange from="5916" to="5916" unit="number"/>
                                        </bibl>.</p>
                                    <p/>
                                </note>
                            </msItem>
                            <msItem>
                                <locus from="115ra" to="172vb" scheme="folios"/>
                                <title type="desc">Commentary on Revelation</title>
                                <rubric>Incipit postilla super apocalipsim</rubric>
                                <incipit>Oportet te iterum (Rev. 10:11) <gap reason="editorial"/> Sicut dixi in principio genesis vetus ac nouum testamentum </incipit>
                                <explicit>gratia domini nostra ihesu christi cum omnibus nobis Amen (Rev. 22:21) Amen Amen Alleluia</explicit>
                                <finalRubric>Explicit postilla fratris N<supplied reason="omitted">icholai</supplied> de lyra Super apocalipsim et <del>perg-</del> super nouum testamentum</finalRubric>
                                <note>
                                    <bibl>
                                        <title type="short" ref="https://www.manuscripta.se/bibl/107105">RB</title>
                                        <citedRange from="5923" to="5923" unit="number"/>
                                    </bibl>.</note>
                            </msItem>
                            <msItem>
                                <locus from="172vb" to="191rb" scheme="folios"/>
                                <title type="desc">Questio ad probandum Christi aduentum</title>
                                <rubric>Sequitur quedam questio ad probandum primum christi aduentum per scripturas a iudeis receptas que quidam questio est ipsius N<supplied reason="omitted">icholai</supplied> de lyra </rubric>
                                <incipit>QVeritur vtrum per scripturas a iudeis Receptas possit probari</incipit>
                                <explicit>et plures iam baptizati ad vomitum Reuertuntur <unclear quantity="12" unit="chars" reason="illegible"/>
                                </explicit>
                                <finalRubric>Explicit questio de probacione per scripturas a iudeis receptas quod misterium christi predictum a lege et prophetis sit impletum determinata a fratre Nicholao de lyra de ordine fratrum minorum </finalRubric>
                                <note>
                                    <bibl>
                                        <title type="short" ref="https://www.manuscripta.se/bibl/107105">RB</title>
                                        <citedRange from="5982" to="5982" unit="number"/>
                                    </bibl>.</note>
                            </msItem>
                            <msItem>
                                <locus from="191rb" to="211vb" scheme="folios"/>
                                <title type="desc">Ad quendam Judeum</title>
                                <rubric>Incipit Responsio fratris N<supplied reason="omitted">icholai</supplied> de lyra ad quendam iudeum ex uerbis eu<del>uangelis</del>uangelii secundum matheum contra christum nequiter arguentem </rubric>
                                <incipit>Potens sit exhortari in doctrina sana et eos qui contradicunt arguere</incipit>
                                <explicit>in aperto mendacio terminauit et cetera et explicit Responsio</explicit>
                                <finalRubric>Explicit Responsio fratris N<supplied reason="omitted">icholai</supplied> de lyra ad quendam iudeum ex uerbis euuangelii secundum matheum contra christum nequiter arguentem Completum est autem protunc hoc opusculum anno domini m<hi rend="super">o</hi> ccc<hi rend="super">o</hi> xxxiiii<hi rend="super">o</hi> in vigilia johannis baptiste</finalRubric>
                                <note>
                                    <p>
                                        <bibl>
                                            <title type="short" ref="https://www.manuscripta.se/bibl/107105">RB</title>
                                            <citedRange from="5980" to="5980" unit="number"/>
                                        </bibl>.</p>
                                    <p>
                                        <locus from="212" to="212" scheme="pages"/>: blank.</p>
                                </note>
                            </msItem>
