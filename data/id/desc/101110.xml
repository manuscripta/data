                            <msItem>
                                <locus from="1r" to="21v" scheme="folios"/>
                                <title type="desc">Ferial Psalter</title>
                                <incipit defective="unknown">Indutus est dominus </incipit>
                                <note>
                                    <p>
                                        There may be parts missing from the beginning as the psalter only contains material for Sunday, Vespers for the weekdays and Compline.</p>
                                    <p>
                                        21v-22v: Major prayers </p>
                                    <p>
                                        22v- : Various memorials beginning with the Trinity </p>
                                    <p>
                                        f. 23r: De sancta cruce; sancta Maria; apostles; de sancto Iohanne; de apostolis;</p>
                                    <p>
                                        f. 23v: de sancto david; reliquis, de omnibus sanctis; pro pace, in dominicis;</p>
                                    <p>
                                        f. 24r: feria ii, feria iii, feria iiii, feria v </p>
                                    <p>
                                        f. 24v: feria vi, nativitate? </p>
                                    <p>
                                        <locus from="SL2r" to="SL8v" scheme="folios"/>: blank.</p>
                                </note>
                            </msItem>
                            <msItem>
                                <locus from="21v" to="22v" scheme="folios"/>
                                <title type="desc">Memorials</title>
                                <rubric>memorie? feriales? dominica? de sancta trinitate</rubric>
                                <incipit>Te deum patrem ingenitum te filium vnigenitum</incipit>
                                <note>
                                    <p>f. 23r: De sancta cruce; sancta Maria; apostles; de sancto Iohanne; de apostolis;</p>
                                    <p>f. 23v: de sancto david; reliquis, de omnibus sanctis; pro pace, in diversis/dominica?</p>
                                    <p>f. 24r: feria ii, feria iii, feria iiii, feria v</p>
                                    <p>f. 24v: feria vi, nativitate?</p>
                                </note>
                            </msItem>
                            <msItem>
                                <locus from="25r" to="101v" scheme="folios"/>
                                <title type="desc">Proper of time</title>
                                <rubric>Dominica prima in aduentus</rubric>
                                <incipit>Fratres scientes quia hora est iam </incipit>
                                <explicit>distribuit discumbentibus similiter et ex piscibus quantum volebat</explicit>
                            </msItem>
                            <msItem>
                                <locus from="101v" to="102r" scheme="folios"/>
                                <title type="desc">Three prayers</title>
                                <incipit>Sancte et indiuidue trinitati ihesu christi crucifixi humanitati quinque wlneribus </incipit>
                                <explicit>veniam omni peccatorum nostrorum consequamur</explicit>
                            </msItem>
                            <msItem>
                                <locus from="102r" to="102r" scheme="folios"/>
                                <title type="desc">Seven penitential psalms</title>
                            </msItem>
                            <msItem>
                                <locus from="106r" to="106r" scheme="folios"/>
                                <title type="desc">Litany</title>
                                <incipit>kyrieleyson christe</incipit>
                                <note>
                                    <p>Notable saints:</p>
                                    <p>St Rimbert (Lund enl. Grotefend);</p>
                                    <p>St Erik;</p>
                                    <p>St Henrik;</p>
                                    <p>St Olav;</p>
                                    <p>St Eskil;</p>
                                    <p>St Botvid; (ej Västerås enligt Grotefend);</p>
                                    <p>St Sigfrid;</p>
                                    <p>St David;</p>
                                    <p>St Elin;</p>
                                    <p>St Birgitta;</p>
                                    <p>St Katarina of Vadstena (twice?).</p>
                                </note>
                            </msItem>
                            <msItem>
                                <locus from="112r" to="190v" scheme="folios"/>
                                <title type="desc">Proper of saints</title>
                                <rubric>In vigilia andree antiphona</rubric>
                                <incipit>Qui persequebatur</incipit>
                                <explicit>accepit illum gaudens in domum suam alleluia hodie salus huic domui a deo facta est alleluia</explicit>
                                <note>
                                    <p>
                                        The proper of saints begins with the vigil for St Andrew and ends with St Linus, followed by Dedicatio ecclesiae. Notable feasts:</p>
                                    <p>
                                        <locus from="115v" to="115v" scheme="folios"/>: St Lazarus (16 Dec.);</p>
                                    <p>
                                        <locus from="117r" to="117r" scheme="folios"/>: St Knut (7 Jan.);</p>
                                    <p>
                                        <locus from="117v" to="117v" scheme="folios"/>: St Joseph (15 Jan.);</p>
                                    <p>
                                        <locus from="119v" to="119v" scheme="folios"/>: St Henrik (19 Jan.);</p>
                                    <p>
                                        <locus from="126r" to="126r" scheme="folios"/>: St Ansgar (3 Feb.);</p>
                                    <p>
                                        <locus from="128r" to="128r" scheme="folios"/>: St Sigfrid (15 Feb.);</p>
                                    <p>
                                        <locus from="140r" to="140r" scheme="folios"/>: St Erik (18 May);</p>
                                    <p>
                                        <locus from="142r" to="142r" scheme="folios"/>: St Botolph (17 May);</p>
                                    <p>
                                        <locus from="144r" to="144r" scheme="folios"/>: St David (25 June);</p>
                                    <p>
                                        <locus from="145v" to="145v" scheme="folios"/>: Sts John and Paul (26 June);</p>
                                    <p>
                                        <locus from="151r" to="151r" scheme="folios"/>: De patronis (after Visitation);</p>
                                    <p>
                                        <locus from="156r" to="156r" scheme="folios"/>: St Botvid (28 July);</p>
                                    <p>
                                        <locus from="156r" to="156r" scheme="folios"/>: St Olav (29 July);</p>
                                    <p>
                                        <locus from="157v" to="157v" scheme="folios"/>: St Elin (31 July);</p>
                                    <p>
                                        <locus from="176v" to="176v" scheme="folios"/>: St Eskil (6 Oct.);</p>
                                    <p>
                                        <locus from="177v" to="177v" scheme="folios"/>: St Birgitta (7 Oct.);</p>
                                    <p>
                                        <locus from="185r" to="185r" scheme="folios"/>: St Edmund (confessor; 16 Nov.);</p>
                                    <p>
                                        <locus from="185v" to="185v" scheme="folios"/>: St Edmund (martyr; 20 Nov.);</p>
                                    <p>
                                        <locus from="188v" to="188v" scheme="folios"/>: Dedicatio ecclesiae.</p>
                                </note>
                            </msItem>
                            <msItem>
                                <locus from="191r" to="191r" scheme="folios"/>
                                <title type="desc">Prayers</title>
                                <incipit>Ave capud coronatum spinis </incipit>
                                <note>f. 191: Prayers on the wounds of Christ; f. 193v-Salutations for the limbs of Christ; Den sista Ave-texten börjar på 192 r. Därpå böner inledda med rubriken Collecta. 193r bön som liknar Leroquais I, 152. NB i marginalen av tidigmodern hand.</note>
                            </msItem>
                            <msItem>
                                <locus from="208v" to="212r" scheme="folios"/>
                                <title type="desc">Collects</title>
                                <rubric>Collecta</rubric>
                                <incipit>OMnipotens sempiterne deus qui Ezechie regi iude cum lacrimis deprecanti vite spacium protendisti</incipit>
                                <explicit>JOBBAR HÄR!! </explicit>
                            </msItem>
                            <msItem>
                                <locus from="212r" to="220r" scheme="folios"/>
                                <title type="desc">Vigiliae mortuorum</title>
                                <incipit>Verba mea auribus percipe domine (Ps 5:2)</incipit>
                                <explicit>Credo In terra? requiescant in Fidelium deus omnium</explicit>
                                <note>
                                    <locus from="220v" to="225r" scheme="folios"/>: blank </note>
                            </msItem>
                            <msItem>
                                <locus from="225v" to="225v" scheme="folios"/>
                                <title type="desc">Prayer</title>
                                <incipit>Aue ancilla trinitatis Aue sponsa spiritus sancti</incipit>
                                <explicit>Rogo te ut </explicit>
                            </msItem>
                            <msItem>
                                <locus from="226r" to="236v" scheme="folios"/>
                                <title type="desc">Common offices</title>
                                <rubric>In vigilia appostolorum</rubric>
                                <incipit>Beatus vir qui inventus est sine macula</incipit>
                                <explicit defective="true">Quia tu es solamen desolatorum spes et mater benigna orphanorum Responsorium Maria </explicit>
