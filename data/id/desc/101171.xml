                            <msItem>
                                <locus from="2v" to="23r" scheme="folios"/>
                                <author>
                                    <persName ref="https://www.manuscripta.se/person/102618"> Thomas à Kempis </persName>
                                </author>
                                <title type="desc">De imitatione Christi</title>
                                <msItem>
                                    <locus from="2v" to="2v" scheme="folios"/>
                                    <title type="desc">Table of contents</title>
                                </msItem>
                                <msItem>
                                    <locus from="3r" to="23r" scheme="folios"/>
                                    <title type="desc">De imitatione Christi, Book 1</title>
                                    <rubric>De ymitacione christi et contemptu omnium vanitatum mundi Capitulum primum </rubric>
                                    <incipit>QVi sequitur me non ambulat in tenebris dicit dominus Hec sunt uerba christi </incipit>
                                    <explicit>Tantum proficies quantum tibi ipsi vim intuleris Amen </explicit>
                                    <finalRubric>Expliciunt ammoniciones ad spiritualem vitam satis vtiles Deo gracias A fratre Thoma kempis ordinis canonicorum regularium in monte sancte Agnetis prope Zuollis edite </finalRubric>
                                    <note>
                                        <locus from="23v" to="24r" scheme="folios"/>: guidelines, but no text.</note>
                                    <bibl>
                                        <title type="short" ref="https://www.manuscripta.se/bibl/107338">Pohl (1903)</title>
                                        <citedRange from="5" to="56" unit="page"/>
                                    </bibl>
                                </msItem>
                            </msItem>
                            <msItem>
                                <locus from="24v" to="24v" scheme="folios"/>
                                <title type="desc">Prayer to the virgin Mary</title>
                                <incipit>Eya mater misericordie virgo incomparabilis</incipit>
                                <explicit>dignitatis videre valeat in eternitatem Amen</explicit>
                            </msItem>
                        </msContents>
                        <physDesc>
                            <objectDesc>
                                <supportDesc material="parchment">
                                    <support>
                                        <p>
                                            <locus from="1" to="24" scheme="folios"/>
