                            <msItem>
                                <locus from="186r" to="275v" scheme="folios"/>
                                <title type="desc">Antiphonary</title>
                                <incipit>Lvmen ad reuelacionem gencium et gloriam plbeis tue israhel</incipit>
                                <explicit>Veneranda uobis domine huius diei festiuitas opem conferat <gap reason="editorial"/> Qui tecum viuit et regnat in vnitate sancte deus per omnia secula seculorum amen</explicit>
                                <note>
                                    <p>
                                        Begins with Purification of the Blessed Virgin Mary (31 Jan), and ends with the Assumption of the Virgin Mary (15 Aug.)</p>
                                    <p>
                                        <locus from="193r" to="193r" scheme="folios"/>. Palm Sunday;</p>
                                    <p>
                                        <locus from="205v" to="205v" scheme="folios"/>: Holy Thursday;</p>
                                    <p>
                                        <locus from="254r" to="254r" scheme="folios"/>: Trinity Sunday; </p>
                                    <p>
                                        <locus from="269v" to="269v" scheme="folios"/>: Assumption;</p>
                                    <p>
                                        <locus from="253v" to="253v" scheme="folios"/>: guidelines, but no text.</p>
                                    <p/>
                                </note>
                            </msItem>
