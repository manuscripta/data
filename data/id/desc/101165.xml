                        <msContents>
                            <textLang mainLang="la"/>
                            <msItem>
                                <locus from="1r" to="91v" scheme="folios"/>
                                <title type="desc">Office for the Virgin Mary</title>
                                <rubric>
                                    <supplied reason="damage">Saluto te</supplied> sancta maria <gap reason="editorial"/> Domine labia mea aperies <gap reason="editorial"/> Invitatorium Regem virignis filium </rubric>
                                <explicit>Nos cum prole pia benedicat virgo maria </explicit>
                            </msItem>
                            <msItem>
                                <locus from="91v" to="100v" scheme="folios"/>
                                <title type="desc">Seven penitential psalms</title>
                                <incipit>Domine ne in furore tuo arguas</incipit>
                                <explicit>Adiutor meus et liberator meus es tu domine ne moreris</explicit>
                            </msItem>
                            <msItem>
                                <locus from="100v" to="107v" scheme="folios"/>
                                <title type="desc">Litany</title>
                                <rubric>Letaniam</rubric>
                                <incipit>Kyrieeleyson Christeleyson</incipit>
                                <explicit>tempora sit tua protectione tranquilla Per christum dominum nostrum</explicit>
                                <note>Prominence of Gertrude (103r, 148v). Getrude invoked on 106r, church of St G, 178r; by a later hand on 185r. Dominic (102v, 148v), note also: Onuphrius (103r, 148v), Long list of female saints (103rv, 148v), St Erasmus (102, 147r) Barlam and Josaphat (148r)</note>
                            </msItem>
                            <msItem>
                                <locus from="107v" to="138r" scheme="folios"/>
                                <title type="desc">Office for the dead</title>
                                <rubric>Vigilia mortuorum </rubric>
                                <incipit>Dilexi quoniam exaudiet dominus</incipit>
                                <explicit>vt qui de hac vita in tui nominis confesione discesserant sanctorum tuorum numero facias aggregari Per christum</explicit>
                            </msItem>
                            <msItem>
                                <locus from="138r" to="139v" scheme="folios"/>
                                <title type="desc">Ordo for the communion of the sick</title>
                                <rubric>ad communicandum infirmum</rubric>
                                <incipit>Ad communincandum infirmum ?mu? vadat prelatus uel ille cui inmererit indutus camisia </incipit>
                                <explicit>et defendat omnes habitantes in hoc habitaculo Per christum</explicit>
                            </msItem>
                            <msItem>
                                <locus from="139v" to="145v" scheme="folios"/>
                                <title type="desc">Anointing of the sick/Last rites</title>
                                <rubric>De estrema vnctione </rubric>
                                <incipit>Ad vngendum infirmum pulsetur signum cum campana</incipit>
                                <explicit>Nisi autem primum ad morientem statim incipiant letaniam </explicit>
                            </msItem>
                            <msItem>
                                <locus from="145v" to="150v" scheme="folios"/>
                                <title type="desc">Litany</title>
                                <rubric>letaniam </rubric>
                                <incipit>Kyrieeleyson Christeeleyson</incipit>
                                <explicit>eius anima representari mereatur Per christum </explicit>
                            </msItem>
                            <msItem>
                                <locus from="150v" to="157v" scheme="folios"/>
                                <title type="desc">Instructions for taking care of the dying</title>
                                <incipit>Finita letania si adhuc virerit dicant fratres vii psalmos sine gloria patri</incipit>
                                <explicit>Quo finito et dicta? preciosa vigilent dicendo psalterium sicut primum</explicit>
                            </msItem>
                            <msItem>
                                <locus from="157v" to="174r" scheme="folios"/>
                                <title type="desc">Office for burial</title>
                                <rubric>de officio sepulture</rubric>
                                <incipit>Cum efferendus est defunctus ad sepeliendum debet </incipit>
                                <explicit>ut dignis flagellacionibus castigatus in tua miseracione respiret Per christum dominum nostrum Amen </explicit>
                            </msItem>
                            <msItem>
                                <locus from="174r" to="177v" scheme="folios"/>
                                <title type="desc">Office of St Dominic</title>
                                <rubric>De sancto dominico Invitatorium</rubric>
                                <incipit>Assunt dominici? leta sollempnia </incipit>
                                <explicit>cum virtutum frequencia clamat pro christi famulo summi regis magnalia Gloria? deo et ?</explicit>
                            </msItem>
                            <msItem>
                                <locus from="177v" to="181v" scheme="folios"/>
                                <title type="desc">Office of St Gertrude</title>
                                <rubric>De sancta gertrudi ad vespera Capitula</rubric>
                                <incipit>Confitebor tibi domine rex et collaudabo te</incipit>
                                <explicit>et aput deum nota? est et aput homines Deo gracias </explicit>
                            </msItem>
                            <msItem>
                                <locus from="181v" to="184v" scheme="folios"/>
                                <title type="desc">Office of the Virgin Mary</title>
                                <rubric>De domina nostra ad vesperas antiphonas </rubric>
                                <incipit>Alma redemptoris mater que per via celi porta manes et stella maris</incipit>
                                <explicit>pro clero intercede pro deuoto femineo sexu alleluia Deo gracias </explicit>
                                <note>
                                    <locus from="185" to="185" scheme="folios"/>: guidelines, but no text. On <locus from="185r" to="185r" scheme="folios"/> an early modern hand has added 6 lines consisting of a prayer to St Gertrud beginning: <quote>Sancta gertrudis intercede pro miseris ad te confugentibus</quote>.</note>
                            </msItem>
