                        <msContents>
                            <summary>
                                <p>Sermons for the period Wednesday after Laetare Sunday to Sunday after Easter, where the text breaks off. The author makes use of patristic authorities, but also frequently refers to or seems to make use of several authors from the 12th to the 14th century, for example Hugh of Saint Victor, Hugh of Sant-Cher, and Simon of Cascia.</p>
                            </summary>
                            <textLang mainLang="la"/>
                            <msItem>
                                <locus from="1r" to="15v" scheme="folios"/>
                                <title type="desc">Feria quarta post letare</title>
                                <rubric>Feria iiii<hi rend="super">a</hi> post letare</rubric>
                                <incipit>Et preteriens ihesus uidit hominem cecum (Joh. 9:1) <gap reason="editorial"/> Post <gap quantity="3" unit="chars" reason="damage"/> ihesus abscondiens se exiuit de templo </incipit>
                                <explicit>et medicum non queritis sed receditis ab illo Ideo peccatum manet</explicit>
                            </msItem>
                            <msItem>
                                <locus from="15v" to="24v" scheme="folios"/>
                                <title type="desc">Feria quinta post letare</title>
                                <rubric>Feria quinta post letare</rubric>
                                <incipit>Ihesus autem respondit discipulis suis et turbis iudeorum (John 5:17) <gap reason="editorial"/> Quia Iudei primam occasionem calumpniandi sumebant contra ihesum</incipit>
                                <explicit>id est ad eternum iudicium et condempnacionem ordinantem </explicit>
                            </msItem>
                            <msItem>
                                <locus from="24v" to="47v" scheme="folios"/>
                                <title type="desc">Feria sexta post letare</title>
                                <rubric>Feria sexta post letare</rubric>
                                <incipit>Erat autem quidam langwens lazarus (Joh. 11:1) <gap reason="editorial"/> Postquam ewangelista ostendit in christo uirtutem viuificatiuam</incipit>
                                <explicit>dei opera odiis insecuntur et infrenare connatur hec ille</explicit>
                            </msItem>
                            <msItem>
                                <locus from="47v" to="54v" scheme="folios"/>
                                <title type="desc">Sabbato ante Iudica</title>
                                <rubric>Sabbato ante Iudica</rubric>
                                <incipit>Iterum locutus est turbis Iudeorum (Joh. 8:12) <gap reason="editorial"/> Confutata Iudeorum purificate hic iam dominus sue doctrine manifestat dignitatem</incipit>
                                <explicit>neque ita eius uirtutem admirabantur nec a malicia desistebant</explicit>
                            </msItem>
                            <msItem>
                                <locus from="54v" to="67r" scheme="folios"/>
                                <title type="desc">Dominica Iudica</title>
                                <rubric>Dominica iudica</rubric>
                                <incipit>Dixit ihesus turbis iudeorum et principibus sacerdotum (Joh. 8:46) <gap reason="editorial"/> Hic ostendit iudeos esse diabolice condicionis imitatores</incipit>
                                <explicit>et in futuro seculo uita <unclear quantity="2" unit="chars" reason="illegible"/>tam Hec Simonio de cassia et cetera</explicit>
                            </msItem>
                            <msItem>
                                <locus from="67r" to="74v" scheme="folios"/>
                                <title type="desc">Feria secunda post Iudica</title>
                                <rubric>Feria secunda post iudica</rubric>
                                <incipit>Audierunt pharisei turbam murmantem (Joh. 7:32) <gap reason="editorial"/> Postquam christus ostendit originem suam </incipit>
                                <explicit>et factos esse dei amicos et tunc suscipere donum id est spiritum sanctum et cetera </explicit>
                            </msItem>
                            <msItem>
                                <locus from="74v" to="82v" scheme="folios"/>
                                <title type="desc">Feria tertia post Iudica</title>
                                <rubric>Feria iii<hi rend="super">a</hi> post Iudica</rubric>
                                <incipit>Dicit eis ihesus Tempus meum (Joh. 7:6) <gap reason="editorial"/> Postquam ewangelista egit de nutrimento spirituali </incipit>
                                <explicit>pro christo sunt locuti audaciter et mortem seuam subierunt et cetera</explicit>
                            </msItem>
                            <msItem>
                                <locus from="82v" to="92v" scheme="folios"/>
                                <title type="desc">Feria quarta post Iudica</title>
                                <rubric>Feria iiii<hi rend="super">a</hi> post Iudica</rubric>
                                <incipit>Facta autem sunt enconia (Joh. 10:22) descripta benignitate christi in docendo </incipit>
                                <explicit>et hic Iohannes non fecerat aliquid signi et cetera </explicit>
                            </msItem>
                            <msItem>
                                <locus from="92v" to="100r" scheme="folios"/>
                                <title type="desc">Feria quinta post Iudica</title>
                                <rubric>Feria v<hi rend="super">a</hi> post Iudica</rubric>
                                <incipit>Ex illa turba cum audissent (7:40) <gap reason="editorial"/> Hic post factam missionem nunciorum notatur</incipit>
                                <explicit>Sic electis mala pene veniunt ad medicinam </explicit>
                            </msItem>
                            <msItem>
                                <locus from="100r" to="105r" scheme="folios"/>
                                <title type="desc">Feria sexta post Iudica</title>
                                <rubric>Feria vi<hi rend="super">a</hi> post iudica</rubric>
                                <incipit>Collegerunt ergo pontifices (Joh. 11:47) <gap reason="editorial"/> Theophilus decebat <add place="above">ad</add>mirari extollere eum</incipit>
                                <explicit>Si modo quando diebus festis tenentur seruire deo tunc maiora et spissius exercent peccata et cetera</explicit>
                            </msItem>
                            <msItem>
                                <locus from="105r" to="150r" scheme="folios"/>
                                <title type="desc">Sabbato ante Domine ne longe</title>
                                <rubric>Sabbato ante domine ne longe</rubric>
                                <incipit>hec locutus est ihesus Et subleuatis (Joh. 17:1) <gap reason="editorial"/> Pro declaracione Huius ewangelii est notandum </incipit>
                                <explicit>ut totus diligat diligantur et membra mea hec Beda </explicit>
                            </msItem>
                            <msItem>
                                <locus from="150r" to="175v" scheme="folios"/>
                                <title type="desc">Feria secunda post Domine ne longe</title>
                                <rubric>Feria ii<hi rend="super">a</hi> post domine ne longe </rubric>
                                <incipit>Ihesus autem ante sex dies pasche (Joh. 12:1) Postquam declarauit ewangelista diuinitatem per opera facta in eius uita</incipit>
                                <explicit>et mandata sua implendo ergo sic offert illam et non aliter et non aliter et cetera</explicit>
                            </msItem>
                            <msItem>
                                <locus from="175v" to="198r" scheme="folios"/>
                                <title type="desc">Feria quinta magna</title>
                                <rubric>Feria quinta magna </rubric>
                                <incipit>Ante diem festum pasche sciens Ihesus (Joh. 13:1) <gap reason="editorial"/> Theophilus Quia domi<supplied reason="omitted">n</supplied>us transmigraturus erat</incipit>
                                <explicit>Tollerabilius erit terre Sodomorum et cetera</explicit>
                                <note>
                                    <locus from="182v" to="182v" scheme="folios"/>: the last five lines of text are written on a pasted on paper note.</note>
                            </msItem>
                            <msItem>
                                <locus from="198r" to="222v" scheme="folios"/>
                                <title type="desc">Feria quarta post pacha</title>
                                <rubric>Feria <sic>quartha</sic> post pascha </rubric>
                                <incipit>Postea manifestauit se iterum ihesus (Joh. 21:1) <gap reason="editorial"/> Hic ponitur tercia apparicio qua manifesta est sua resurrectio</incipit>
                                <explicit>christus tradidit in exemplum dicens sibi Sequite me</explicit>
                            </msItem>
                            <msItem>
                                <locus from="222v" to="236r" scheme="folios"/>
                                <title type="desc">Feria quinta post pacha</title>
                                <rubric>Feria quinta post pascha </rubric>
                                <incipit>Maria autem stabat ad monumentum foris (Joh. 20:11) <gap reason="editorial"/> Ponito quoniam maria magdalena pervenit ad sepulcri apercionem</incipit>
                                <explicit>deum in breui ascensurum se asserit hec Simon</explicit>
                            </msItem>
                            <msItem>
                                <locus from="236r" to="242r" scheme="folios"/>
                                <title type="desc">Sabbato post pascha</title>
                                <rubric>Sabbato post pascha </rubric>
                                <incipit>Vna autem sabbati maria magdalene venit (Joh. 20:1) <gap reason="editorial"/> Postquam descripsit christi crucifixionem et mortem </incipit>
                                <explicit>et scrutabor legem tuam et custodiam illam in toto corde meo (Ps. 118:34)</explicit>
                            </msItem>
                            <msItem>
                                <locus from="242r" to="248v" scheme="folios"/>
                                <title type="desc">Dominica prima post pascha</title>
                                <rubric>Dominica prima post pascha</rubric>
                                <incipit>Cum ergo sero esset die illa vna sabbatorum (Joh. 20:19) <gap reason="editorial"/> Facta apparicione mulieribus hic conuertet/conuenienter? agit de apparicione</incipit>
                                <explicit defective="true">reprehensionis superbia culpa que non erat fiat Sed</explicit>
                                <note>
                                    <locus from="S249r" to="S259v" scheme="folios"/>: blank.</note>
                            </msItem>
                        </msContents>
