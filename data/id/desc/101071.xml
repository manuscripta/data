                        <msContents>
                            <textLang mainLang="la"/>
                            <msItem>
                                <locus from="2r" to="18v" scheme="folios"/>
                                <author>
                                    <persName ref="https://www.manuscripta.se/person/102550">Jacobus Nicholai de Dacia</persName>
                                </author>
                                <title type="uniform">Recommendatio parvula sive Salutatio beatae Mariae</title>
                                <rubric>Salutacio beate marie uirginis gloriose</rubric>
                                <incipit>Salue sancta parens dei. Salue mater noster spei.</incipit>
                                <explicit defective="false">Et securos nos conducet. Lux que sine fine lucet Per suam clemenciam Amen.</explicit>
                                <note>
                                    <p>
                                        <locus from="18v" to="18v" scheme="folios"/> An addition by the scribe: </p>
                                    <p>
                                        <quote xml:lang="la">Istud salve subscriptum stare debet in tercio folio precedenti ad tale signum quod sequitur</quote> (reference sign) + six lines of verse. The corresponding reference sign is found on <locus from="16r" to="16r" scheme="folios"/> where <quote xml:lang="la">in fine stat</quote> has also been written in the margin. </p>
                                    <p/>
                                    <p/>
                                    <p> According to <bibl>
                                            <title type="short" ref="https://www.manuscripta.se/bibl/107140">Kabell (1967)</title>
                                            <citedRange from="24" to="24" unit="page"/>
                                            <citedRange from="40" to="40" unit="footnote"/>
                                        </bibl> one bifolium of the manuscript is probably missing since the original number of the double strophes should be 150. </p>
                                </note>
                            </msItem>
                        </msContents>
                        <physDesc>
                            <objectDesc>
                                <supportDesc material="parchment">
                                    <support>
                                        <p>
                                            <locus from="1r" to="19v" scheme="folios"/>
                                            <material>Parchment</material>
