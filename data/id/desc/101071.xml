                                            <width quantity="100" unit="mm"/>
                                        </dimensions>
                                    </layout>
                                </layoutDesc>
                            </objectDesc>
                            <handDesc>
                                <handNote xml:id="hand-1">Hybrida</handNote>
                            </handDesc>
                            <additions>
                                <p>
                                    <locus from="1r" to="1r" scheme="folios"/>
                                    <note>Upper right corner in black ink by a modern hand: <quote xml:lang="sv">18 Blad 1846.</quote>
                                    </note>
                                </p>
                                <p>
                                    <locus from="1v" to="1v" scheme="folios"/>
                                    <note>Upper part of page in brown ink (with capitals touched in red) by a medieval hand: <quote>Incipit recommendacio paruula siue salutacio beate marie genitricis dei omnipotentis et virginis gloriose</quote>. Below the title a contemporary hand has written: <quote xml:lang="la">probacio penne</quote>. Bottom of the page by the same hand that wrote the title: <quote xml:lang="la">Per quendam scolarem de regno dacie</quote> Below this a pen-trial in faded brown ink. </note>
                                </p>
                                <p>
                                    <locus from="2r" to="2r" scheme="folios"/>
                                    <note>Top of page in pencil/lead: <quote>27</quote>.</note>
                                </p>
                                <p>
                                    <locus from="5v" to="5v" scheme="folios"/>
                                    <note> Outer margin in brown ink within a frame by the scribe or a contemporary hand: <quote>Roskildis</quote>. </note>
                                </p>
                                <p>
                                    <locus from="5v" to="16r" scheme="folios"/>
                                    <note>Short additions or corrections (one word or short phrases) by a contemporary hand in the margins.</note>
                                </p>
                                <p>
                                    <locus from="19r" to="19r" scheme="folios"/>
                                    <note>The entire page is covered by a double frame containing a x-shape drawn in darkbrown ink. In the upper part of the frame the scribe or a contemporary hand has written: <quote xml:lang="la">Salue sancta ? et omni cause</quote> Below the lower part of the frame: <quote xml:lang="la">sic deformetur per furtum ne rapiatur folium hoc</quote>
                                    </note>
                                </p>
                                <p>
                                    <locus from="19v" to="19v" scheme="folios"/>
                                    <note>A similar frame to that on <locus from="19r" to="19r" scheme="folios"/> filled with pen-trials (of which some are words and others just letters). Above the frame two lines have been written, but the text is too faded and damaged to make out.</note>
                                </p>
                            </additions>
                            <decoDesc>
                                <p>Main text in brown ink, capitals touched in red,</p>
                                <decoNote type="initials">
                                    <p>
                                        <locus from="2r" to="2r" scheme="folios"/> Opening plain initial S over 2 lines (+ extending above and below the line) in blue with red flourishing. </p>
                                </decoNote>
                            </decoDesc>
