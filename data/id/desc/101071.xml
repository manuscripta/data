                                        <measure type="textblockLeaves" quantity="19" unit="folios"/>
                                    </extent>
                                    <condition>
                                        <locus from="1" to="1" scheme="folios"/> loose leaf, almost detached. <locus from="4" to="4" scheme="folios"/> Circa 80% of the page cut out. Words or parts of words from 10 lines are visible on 4r, on 4v only two words. <locus from="1" to="1" scheme="folios"/> and <locus from="19" to="19" scheme="folios"/> dirty and with holes in the page. Sewing loose in both quires. </condition>
                                </supportDesc>
                                <layoutDesc>
                                    <layout columns="1" writtenLines="24">
                                        <locus from="1r" to="19v" scheme="folios"/>
