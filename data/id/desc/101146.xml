                    <history>
                        <origin>
                            <p>
                                <origPlace>
                                    <placeName cert="low" ref="https://www.manuscripta.se/place/100208">Austria</placeName>
                                </origPlace>, <origDate when="1395">1395</origDate>. Dating based on colophon on <locus from="189" to="189" scheme="pages"/>. Künzle argues that the manuscript may stem from a Cistercian monastery in Austria (see <bibl>
                                    <title type="short" ref="https://www.manuscripta.se/bibl/107426">Künzle (1977)</title>
                                    <citedRange from="178" to="178" unit="page"/>
                                </bibl>). Earlier Lehmann had argued that the manuscript might have been written in a Dominican monastery in <placeName ref="https://www.manuscripta.se/place/100322">Soest</placeName> (<bibl>
                                    <title type="short" ref="https://www.manuscripta.se/bibl/107421">Lehmann (1935)</title>
                                    <citedRange from="125" to="126" unit="page"/>
                                </bibl>). An addition to the colophon states that the text was written by <quote>brother Tilmann</quote>.</p>
                        </origin>
                        <provenance>
                            <p>Provenance unknown. During the 19th century the manuscript belonged to the book dealer and collector <persName ref="https://www.manuscripta.se/person/102681"> Fidelis Butsch </persName> in <placeName ref="https://www.manuscripta.se/place/100004">Augsburg</placeName>.</p>
                        </provenance>
                        <acquisition>
                            <p>Purchased by the <orgName ref="https://www.manuscripta.se/org/100004">National Library</orgName> from <persName ref="https://www.manuscripta.se/person/102681">F. Butsch</persName> in <placeName ref="https://www.manuscripta.se/place/100004">Augsburg</placeName> in June <date when="1870"/>.</p>
                        </acquisition>
                    </history>
