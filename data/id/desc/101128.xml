                        <additions>
                            <p>
                                <locus from="S1r" to="S1r" scheme="folios"/>
                                <note>Top of page in black ink: <quote xml:lang="sv">Kgl Bibl. 1734 års Kat no 12. Theol. in fol.</quote>. Middle of the page in black ink: <quote xml:lang="la">Epistolae Sancti Pauli Apostoli. cum Commentariis et glossis</quote>. Below in pencil: <quote xml:lang="sv">Från S.t Légers kapell i Loudun (nära Poitiers) (kapellet tilhörde grefvarnas af Anjou slott; är nu museum).</quote>
                                </note>
                            </p>
                            <p>
                                <locus from="RCI" to="RCI" scheme="other"/>
