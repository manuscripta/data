                        <msContents>
                            <textLang mainLang="la"/>
                            <msItem>
                                <locus from="2r" to="23v" scheme="folios"/>
                                <textLang mainLang="la"/>
                                <title type="desc">Hymns from the Cantus Sororum</title>
                                <rubric>Ymnus ad matutinum</rubric>
                                <incipit>O Trinitatis gloria celestis decus curie</incipit>
                                <explicit>trinum deum glorifice. pro te tam digna laudibus Maria Gloria</explicit>
                                <bibl>
                                    <title type="short" ref="https://www.manuscripta.se/bibl/107120">AH</title>
                                    <citedRange from="48" to="48" unit="volume"/>
                                    <citedRange from="366" to="382" unit="number"/>
                                </bibl>
                            </msItem>
                            <msItem>
                                <locus from="23v" to="40v" scheme="folios"/>
                                <textLang mainLang="la"/>
                                <title type="desc">Hymns and Antiphons</title>
                                <incipit>Veni creator spiritus mentes tuorum imple</incipit>
                                <explicit>In te domine. speraui non confundar in eternum</explicit>
                                <note>
                                    <p>
                                        <locus from="23v" to="23v" scheme="folios"/>: Veni creator spiritus.</p>
                                    <p>
                                        <locus from="24v" to="24v" scheme="folios"/>: <quote>Ruine celi curie</quote>, a hymn to Birgitta, also known as <quote>Ruinae coeli civium</quote> (<bibl>
                                            <title type="short" ref="https://www.manuscripta.se/bibl/101486">AH</title>
                                        </bibl>, vol. 23, no 251).</p>
                                    <p>
                                        <locus from="25v" to="28r" scheme="folios"/>: Antiphons to the Virgin (Ave regina celorum; Regina celi; Virgo mater resurgentis).</p>
                                    <p>
                                        <locus from="29r" to="40v" scheme="folios"/>Te Deum.</p>
                                </note>
                            </msItem>
                        </msContents>
