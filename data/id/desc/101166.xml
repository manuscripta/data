                        <msContents>
                            <textLang mainLang="la" otherLangs="de"/>
                            <msItem>
                                <locus from="1v" to="1v" scheme="folios"/>
                                <title type="desc">Prayers for saints</title>
                                <incipit>Presta quesumus omnipotens deus</incipit>
                                <explicit>quesumus domine natalicia nobis votiua <sic>replendeant</sic>
                                </explicit>
                            </msItem>
                            <msItem>
                                <locus from="2r" to="7v" scheme="folios"/>
                                <title type="desc">Calendar</title>
                                <note>
                                    <p> Notable feasts:</p>
                                    <p>
                                        <locus from="2r" to="2r" scheme="folios"/>: translation of St Thomas Aquinas (28 Jan.);</p>
                                    <p>
                                        <locus from="3r" to="3r" scheme="folios"/>: St Thomas Aquinas (7 Mar.);</p>
                                    <p>
                                        <locus from="3v" to="3v" scheme="folios"/>: St Vincent Ferrer (5 Sep.);</p>
                                    <p>
                                        <quote>Elisabet Wylerin anno mcccclxxxiiii</quote> (16 Apr., added by another hand);</p>
                                    <p>
                                        <locus from="4r" to="4r" scheme="folios"/>: translation of St Dominic (24 May);</p>
                                    <p>
                                        <locus from="6r" to="6r" scheme="folios"/>: St Wenceslaus (28 Sep.).</p>
                                    <p>
                                        <locus from="5v" to="5v" scheme="folios"/>: St Dominic (4 Aug.);</p>
                                    <p>
                                        <locus from="6v" to="6v" scheme="folios"/>: Anniuersarium omnium fratrum et sororum ordinis (10 Oct.).</p>
                                </note>
                            </msItem>
                            <msItem>
                                <locus from="8r" to="10v" scheme="folios"/>
                                <title type="desc">Commemorations</title>
                                <rubric>Memoria quottidiana</rubric>
                                <incipit>REgali ex progenie maria exorta refulget</incipit>
                                <explicit>te auxiliante semper salui esse mereamur Per</explicit>
                            </msItem>
                            <msItem>
                                <locus from="11r" to="17v" scheme="folios"/>
                                <title type="desc">Offices for various occasions</title>
                                <rubric xml:lang="de">So man ix letzen helt</rubric>
                                <incipit>Iube dompna benedicere </incipit>
                                <explicit>Saluam fac anullam tuam Deus meus sperantem</explicit>
                                <note>Rubrics in German.</note>
                            </msItem>
                            <msItem>
                                <locus from="18r" to="53v" scheme="folios"/>
                                <title type="desc">Office of the Virgin Mary</title>
                                <rubric>Incipit cursus de beata uirgine maria <gap reason="editorial"/> Inuitatorium Regem uirginis filium</rubric>
                                <incipit>DOmine labia mea aperies</incipit>
                                <explicit>Carnis resurrectionem Et uitam eternam Amen</explicit>
                            </msItem>
                            <msItem>
                                <locus from="53v" to="126v" scheme="folios"/>
                                <title type="desc">Proper of time</title>
                                <rubric>Ad primam</rubric>
                                <incipit>Deus in adiutorium Domine ad</incipit>
                                <explicit>et dicebant quia hic est saluator mundi</explicit>
                                <note>It is unclear with which feast the The Proper of time starts, it ends with the Twenty-fifth Sunday after Trinity.</note>
                            </msItem>
                            <msItem>
                                <locus from="126v" to="154v" scheme="folios"/>
                                <title type="desc">Office for the dead</title>
                                <rubric>vespere defunctorum antiphona</rubric>
                                <incipit>Placebo DIlexi quoniam exaudiet</incipit>
                                <explicit>ut a cunctibus reatibus absoluti tecum sine fine letentur Per</explicit>
                            </msItem>
                            <msItem>
                                <locus from="154v" to="163v" scheme="folios"/>
                                <title type="desc">Seven penitential psalms</title>
                                <rubric>Incipiunt septem psalmi penitentiales </rubric>
                                <incipit>DOmine ne in furore tuo arguas </incipit>
                                <explicit>Adiutor meus et liberator meus es tu domine ne moreris</explicit>
                            </msItem>
                            <msItem>
                                <locus from="163v" to="173v" scheme="folios"/>
                                <title type="desc">Litanies</title>
                                <incipit>KYrie eleison Christeleison</incipit>
                                <explicit>Requiescant in pace Amen</explicit>
                                <note>
                                    <p>
                                        <locus from="163v" to="163v" scheme="folios"/>: first litany;</p>
                                    <p>
                                        <locus from="169v" to="169v" scheme="folios"/>: second litany.</p>
                                </note>
                            </msItem>
                            <msItem>
                                <locus from="173v" to="179r" scheme="folios"/>
                                <title type="desc">Psalms</title>
                                <rubric>psalmus dauid</rubric>
                                <incipit>DEus deus meus respice</incipit>
                                <explicit>Quicumque uult</explicit>
                                <note>Psalms 21-25, and 5 psalms with only incipit.</note>
                            </msItem>
                            <msItem>
                                <locus from="179r" to="183r" scheme="folios"/>
                                <title type="desc">Office for St Dominic</title>
                                <rubric>De sancto dominici Capitulum</rubric>
                                <incipit>QVasi stella matutina in medio nebule</incipit>
                                <explicit>Iustus germinabit</explicit>
                            </msItem>
                            <msItem>
                                <locus from="183r" to="199r" scheme="folios"/>
                                <title type="desc">Common of saints</title>
                                <rubric>De communi appostolorum antiphona </rubric>
                                <incipit>Estote fortes in bello</incipit>
                                <explicit>ita pie deuocionis erudiamur effectu Per</explicit>
                                <note>
                                    <p>
                                        <locus from="183r" to="183r" scheme="folios"/>: Common of apostles;</p>
                                    <p>
                                        <locus from="185v" to="185v" scheme="folios"/>: Common of evangelists;</p>
                                    <p>
                                        <locus from="186v" to="186v" scheme="folios"/>: Common of one martyr;</p>
                                    <p>
                                        <locus from="188v" to="188v" scheme="folios"/>: Common of many martyrs;</p>
                                    <p>
                                        <locus from="191v" to="191v" scheme="folios"/>: Common of confessors;</p>
                                    <p>
                                        <locus from="193v" to="193v" scheme="folios"/>: Common of virgins;</p>
                                    <p>
                                        <locus from="196r" to="199r" scheme="folios"/>: prayers for the Common of saints.</p>
                                </note>
                            </msItem>
                            <msItem>
                                <locus from="199r" to="204v" scheme="folios"/>
                                <title type="desc">Proper prayers for the saints</title>
                                <rubric>De sancta barbara uirgine Oracio </rubric>
                                <incipit>
                                    <sic>BEus</sic> ad quem hodierna die </incipit>
                                <explicit>et celebrando proficere Per </explicit>
                                <finalRubric>de sancto Johanne</finalRubric>
                                <note>The last rubric is not followed by a prayer; on <locus from="205r" to="205r" scheme="folios"/> there are additional prayers by another hand.</note>
                            </msItem>
                            <msItem>
                                <locus from="205v" to="207r" scheme="folios"/>
                                <title type="desc">Sequence and prayer to the Virgin Mary</title>
                                <incipit>MIsereatur tui omnipotens deus </incipit>
                                <explicit>ecclesia tua secura tibi seruiat libertate Per christum</explicit>
                            </msItem>
                            <msItem>
                                <locus from="207v" to="223r" scheme="folios"/>
                                <title type="desc">Psalter</title>
                                <incipit>BEatus uir qui non abiit</incipit>
                                <explicit>quoniam sanctus dominus deus noster</explicit>
                                <note>
                                    <p> Psalms 1-3; 4-8 (only incipit), 10, 14-15, 20, 32-33, 44-46, 60, 63, 74, 86, 95-98.</p>
                                    <p>
                                        <locus from="223r" to="223v" scheme="folios"/>: Proper prayers for saints added by another hand.</p>
                                </note>
                            </msItem>
                        </msContents>
