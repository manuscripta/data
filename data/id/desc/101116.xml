                                    <measure type="rightFlyleaves" quantity="2" unit="folios"/>
                                </extent>
                                <foliation>Modern foliation in pencil. </foliation>
                                <collation>
                                    <p>The fragment consists of one quire of ten leaves.</p>
                                </collation>
                                <condition>
                                    <locus from="SL1" to="SL1" scheme="folios"/> detached. <locus from="SL2" to="SL2" scheme="folios"/> and <locus from="SR1" to="SR1" scheme="folios"/> are water damaged.</condition>
