                    <history>
                        <origin>
                            <p>
                                <origDate notAfter="1500" notBefore="1401">15th century</origDate>. Dating based on the inclusion of texts by St Birgitta.</p>
                        </origin>
                        <provenance>
                            <p>Early provenance unknown. The text on <locus from="SL1r" to="SL1r" scheme="folios"/> and <locus from="SL2r" to="SL2r" scheme="folios"/> indicates that the fragment was previously bound with <ref target="https://manuscripta.se/ms/101558">Isl. papp. 8:o 21</ref>, a modern volume containing miscellaneous Icelandic texts and fragments of texts from four different 17th century manuscripts. Three of these manuscripts were written in <placeName ref="https://www.manuscripta.se/place/100209">Iceland</placeName>, and the fourth in <placeName ref="https://www.manuscripta.se/place/100081">Sweden</placeName>.</p>
                        </provenance>
                        <acquisition>
                            <p>Transferred from the <orgName ref="https://www.manuscripta.se/org/100059">Antiquities Archive</orgName> to the <orgName ref="https://www.manuscripta.se/org/100004">Royal Library</orgName>.</p>
                        </acquisition>
                    </history>
