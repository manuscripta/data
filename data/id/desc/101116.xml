                                            <locus from="SL2" to="SL2" scheme="folios"/>
                                            <locus from="SL1" to="SL1" scheme="folios"/>
                                        </locusGrp>
                                        <material>Parchment</material>
                                        <note>
                                            <locus from="SL2" to="SL2" scheme="folios"/> and <locus from="SR1" to="SR1" scheme="folios"/> are stiff parchment leaves, which were probably once used as a cover for the booklet.</note>
                                        <dimensions type="leaf">
