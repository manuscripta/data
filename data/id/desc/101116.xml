                                <locus from="1r" to="1v" scheme="folios"/>
                                <title type="desc">Excerpt from Vitas patrum</title>
                                <incipit>Uenit aliquando abbas ysaac in cenobium et vidit illic fratrem negligentem </incipit>
                                <explicit>quia fratrem tuum in tempore temptacionis despexisti</explicit>
                                <bibl>
                                    <title type="short" ref="https://www.manuscripta.se/bibl/107168">PL</title>
                                    <citedRange from="73" to="73" unit="volume"/>
                                    <citedRange from="786" to="787" unit="column"/>
                                </bibl>
                            </msItem>
                            <msItem>
                                <locus from="2r" to="5v" scheme="folios"/>
                                <title type="desc">Excerpts from St Birgitta, Revelations, and unidentified texts</title>
                                <incipit>Quidam miles potentissmus multum odiuit clerum</incipit>
                                <explicit>non omnes demones eos retinere possunt</explicit>
                                <note>
                                    <p>
                                        <locus from="2r" to="2v" scheme="folios"/>: fragments from St Birgitta, Rev. 1:17, 1-5 (the first lines are from the Declaration on p. 288), on <locus from="2v" to="3r" scheme="folios"/> follows an unidentified text.</p>
                                    <p>
                                        <locus from="3v" to="4v" scheme="folios"/>: blank.</p>
                                    <p>
                                        <locus from="5r" to="5r" scheme="folios"/>: possibly part of a sermon;</p>
                                    <p>
                                        <locus from="5v" to="5v" scheme="folios"/>: St Birgitta, Rev. 2:19, 1-8;</p>
                                    <p>
                                        <locus from="6r" to="10v" scheme="folios"/> blank.</p>
                                </note>
                                <listBibl>
