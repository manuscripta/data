                    <head>Vitas patrum, St Birgitta, unidentified texts (fragment)</head>
                    <physDesc>
                        <objectDesc form="codex">
                            <supportDesc>
                                <support>
                                    <p>
                                        <locusGrp>
                                            <locus from="LCI" to="LCI" scheme="other"/>
                                            <locus from="SL1" to="SL1" scheme="folios"/>
                                            <locus from="SR2" to="SR2" scheme="folios"/>
