                    <msPart>
                        <msIdentifier>
                            <idno type="codicologicalUnit">1</idno>
                        </msIdentifier>
                        <msContents>
                            <summary>
                                <p>Fragment of a Gelasian sacramentary containing parts from the <quote>Missa tam vivorum quam defunctorum</quote>, <quote>Super oblata</quote>, <quote>Missa abbatis et congregationis sibi comissae</quote>, and<quote>Missa votiva communis viventium</quote>, as identified by <bibl>
                                        <title ref="https://www.manuscripta.se/bibl/107187" type="short">Lehmann (1934)</title>
                                        <citedRange unit="page" from="166" to="167">page 166–167.</citedRange>
                                    </bibl></p>
                            </summary>
                            <textLang mainLang="la"/>
                            <msItem>
                                <locus from="S1r" to="S1r" scheme="folios"/>
                                <quote>Omnipotens sempiterne deus qui uiuorum dominaris simul <lb/>
                                    <supplied reason="omitted">predesti</supplied>nationis Liber adsripta retineat p Postcommunio Purificent nos quesumus</quote>
                            </msItem>
                            <msItem>
                                <locus from="S1v" to="S1v" scheme="folios"/>
                                <quote>et ut in ueritate tibi conplaceant perpetuum eis rorem tue benedictionis <lb/>
                                    <supplied reason="omitted">celes</supplied>ti protege benignus auxilium Per igitur obl<supplied reason="illegible">ation</supplied>em</quote>
                            </msItem>
                        </msContents>
                        <physDesc>
                            <objectDesc>
                                <supportDesc material="parchment">
                                    <support>
