                    <head>Gelasian Sacramentary (fragment)</head>
                    <physDesc>
                        <objectDesc form="fragment">
                            <supportDesc>
                                <extent>
                                    <measure type="leftFlyleaves" unit="folios"/>
                                    <measure type="rightFlyleaves" unit="folios"/>
                                </extent>
                            </supportDesc>
                        </objectDesc>
                        <bindingDesc>
                            <binding contemporary="false">
                                <p>The fragment is mounted on cardboard (<locus from="Board" to="Board" scheme="folios"/>) and stored in a modern folder.</p>
                            </binding>
                        </bindingDesc>
                    </physDesc>
                    <history>
                        <origin>
                            <p>
                                <origPlace>
                                    <placeName ref="https://www.manuscripta.se/place/100036">Italy</placeName>
                                    <placeName ref="https://www.manuscripta.se/place/100361" cert="low">Ravenna</placeName>
                                </origPlace>, <origDate notBefore="0700" notAfter="0725">8th century, first quarter</origDate>. Place of orgin and dating based on <bibl>
                                    <title ref="https://www.manuscripta.se/bibl/107556" type="short">Gamber (1958)</title>
                                </bibl>.</p>
                        </origin>
                        <provenance>
                            <p>Early provenance unknown.</p>
                        </provenance>
                        <provenance>
                            <p>The fragment is related to a fragment kept at the University Library of Wroclaw, <ref target="https://bibliotekacyfrowa.pl/publication/84013">Akc. 1955/3</ref>.</p>
                        </provenance>
                        <acquisition>
                            <p>The fragment was once found in <ref target="https://regina.kb.se/permalink/f/18bmuqo/46KBS_ALEPH_DS001254496">Liber Canonis Avicenne (Venice 1507)</ref>, where it was discovered by <persName ref="https://www.manuscripta.se/person/102502">I. Collijn</persName>. However, this book has been rebound and contains no traces of previous owners.</p>
                        </acquisition>
