                                <incipit>GAude cetus fidelium henrici natalicium letis extollens canticis</incipit>
                                <explicit defective="true">et sanitati restituta plene conualuit </explicit>
                                <note>The fragment consists of antiphons and readings for vespers, matins with two nocturns. For a similar text, see <bibl>
                                        <title ref="https://www.manuscripta.se/bibl/107317" type="short">Klemming (1885)</title>
                                        <citedRange unit="page" from="125" to="135"/>
